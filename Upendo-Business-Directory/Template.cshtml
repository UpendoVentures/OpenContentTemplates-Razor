@using System
@using System.Collections.Generic
@using System.Collections.Specialized
@using System.Web
@using DotNetNuke.Entities.Modules
@using Upendo.SkinObjects.OpenContentHelper.Helpers
@using Upendo.OpenContentHelper.Features.Directory
@using Upendo.OpenContentHelper.Features.Directory.Common
@using Upendo.OpenContentHelper.Features.Directory.Helpers
@using Upendo.OpenContentHelper.Features.Directory.Models
@using Upendo.OpenContentHelper.Features.Seo.Helpers

@inherits Satrabel.OpenContent.Components.OpenContentWebPage

@{
    RegisterStyleSheet("css/template.css");

    // Hide admin border
    TemplateHelper.HideAdminBorder(Dnn.Module.ModuleID, Dnn.Module.TabID);

    int portalId = -1;
    if (Dnn != null && Dnn.Portal != null)
    {
        portalId = Dnn.Portal.PortalId;
    }

    int tabId = -1;
    if (Dnn != null && Dnn.Tab != null)
    {
        tabId = Dnn.Tab.TabID;
    }

    var request = HttpContext.Current.Request;
    string currentQuery = DirectoryHelper.CurrentQueryStrings();

    // detail support
    CompanyDetail company = null;
    bool isCompanyDetail = false;
    string companySlugFromPath = null;

    // directory support
    DirectorySearchRequest req = new DirectorySearchRequest();
    List<CategoryDto> categories = new List<CategoryDto>();
    List<CompanyDirectoryItem> items = new List<CompanyDirectoryItem>();
    DirectorySearchWithCategoriesResult search = new DirectorySearchWithCategoriesResult();
    int totalCount = 0;
    int totalPages = 1;
    int page = 1;
    int pageSize = 24;
    int from = 0;
    int to = 0;
    string companyDetailRelativeUrl = string.Empty;
    string companyDetailAbsoluteUrl = string.Empty;

    if (DirectoryRequestHelper.TryGetCompanyDetailSlug(request, out companySlugFromPath))
    {
        /*------------------------------------------------------------
        * COMPANY DETAIL VIEW
        *------------------------------------------------------------*/
        isCompanyDetail = true;
        company = ChamberMembershipController.GetCompanyBySlug(portalId, companySlugFromPath);

        if (company != null)
        {
            companyDetailRelativeUrl = DirectoryPageUrlHelper.BuildCompanyDetailUrl(
                DirectoryConstants.DirectoryListPageRoute,
                company.Slug
            );

            companyDetailAbsoluteUrl = request.Url.Scheme + "://" + request.Url.Authority + companyDetailRelativeUrl;
        }
    }
    else
    {
        /*------------------------------------------------------------
        * SEARCH/DIRECTORY VIEW
        *------------------------------------------------------------*/
        // existing listing/search logic
        var sort = (Request.QueryString["sort"] ?? "default").Trim().ToLowerInvariant();
        var rsRaw = (Request.QueryString["rs"] ?? string.Empty).Trim();
        int rs;
        var hasSeed = int.TryParse(rsRaw, out rs) && rs > 0;

        if (sort == "default" && !hasSeed)
        {
            // Generate a one-time seed
            var seed = new Random().Next(1, int.MaxValue);

            // Preserve all existing querystring values
            var qs = System.Web.HttpUtility.ParseQueryString(Request.QueryString.ToString());
            qs.Set("rs", seed.ToString());
            qs.Set("page", "1"); // reset paging on new order

            var redirectUrl = Request.Url.AbsolutePath + "?" + qs.ToString();
            Response.Redirect(redirectUrl, true);
        }

        req = ChamberMembershipController.ParseRequest(HttpContext.Current.Request);
        if (req.Sort == "default" && (!req.RandomSeed.HasValue || req.RandomSeed.Value <= 0))
        {
            throw new InvalidOperationException(
                "Default sort requires a random seed (rs) to be present in the query string."
            );
        }

        // Explicitly remove unsupported filters (overrides the controller)
        req.City = null;
        req.MembershipStatus = null;
        req.FeaturedOnly = false;

        if (string.IsNullOrWhiteSpace(req.Sort))
        {
            req.Sort = "default";
        }

        if (req.Page < 1)
        {
            req.Page = 1;
        }

        if (req.PageSize < 1)
        {
            req.PageSize = 24;
        }

        if (req.PageSize > 50)
        {
            req.PageSize = 50;
        }

        // ----------------------------
        // Load categories
        // ----------------------------
        categories = new List<CategoryDto>();
        var rawCats = ChamberMembershipController.GetActiveCategories(portalId);
        if (rawCats != null)
        {
            foreach (var c in rawCats)
            {
                if (c != null)
                {
                    categories.Add(c);
                }
            }
        }

        // ----------------------------
        // Search
        // ----------------------------
        search = DirectorySearchWithCategoriesResult.SearchCompaniesWithCategoryNames(portalId, req);

        items = new List<CompanyDirectoryItem>();
        totalCount = 0;

        if (search != null && search.Results != null)
        {
            totalCount = search.Results.TotalCount;
            if (search.Results.Items != null)
            {
                foreach (var it in search.Results.Items)
                {
                    if (it != null)
                    {
                        items.Add(it);
                    }
                }
            }
        }

        page = req.Page;
        pageSize = req.PageSize;

        totalPages = 1;
        if (totalCount > 0)
        {
            totalPages = (int)Math.Ceiling((double)totalCount / (double)pageSize);
            if (totalPages < 1)
            {
                totalPages = 1;
            }
        }

        if (page > totalPages)
        {
            page = totalPages;
        }

        from = 0;
        to = 0;
        if (totalCount > 0)
        {
            from = ((page - 1) * pageSize) + 1;
            to = page * pageSize;
            if (to > totalCount)
            {
                to = totalCount;
            }
        }

        // If page was clamped (e.g. user requested page 999), re-run the search
        if (page != req.Page)
        {
            req.Page = page;

            search = DirectorySearchWithCategoriesResult.SearchCompaniesWithCategoryNames(portalId, req);

            items.Clear();
            totalCount = 0;

            if (search != null && search.Results != null)
            {
                totalCount = search.Results.TotalCount;

                if (search.Results.Items != null)
                {
                    foreach (var it in search.Results.Items)
                    {
                        if (it != null)
                        {
                            items.Add(it);
                        }
                    }
                }
            }

            // Recompute range values
            from = 0;
            to = 0;

            if (totalCount > 0)
            {
                from = ((page - 1) * pageSize) + 1;
                to = page * pageSize;
                if (to > totalCount)
                {
                    to = totalCount;
                }
            }
        }
    }    
}

@if (!string.IsNullOrEmpty(Model.ModuleAnchor))
{
    <div id="@Model.ModuleAnchor"></div>
}

@if (isCompanyDetail)
{
    var backToDirectoryUrl = DotNetNuke.Common.Globals.NavigateURL(tabId) + currentQuery;

    // Render detail view
    if (company == null)
    {
        <div class="alert alert-light border rounded-4">
            Business not found.
            <a class="ms-2" href="@backToDirectoryUrl">Back to Directory</a>
        </div>
    }
    else
    {
        string logoUrl = ChamberMembershipController.ResolveLogoUrl(portalId, company.LogoFileId, company.LogoUrl);
        string primaryCategory = ChamberMembershipController.GetPrimaryCategoryName(company);
        string primaryEmail = ChamberMembershipController.GetPrimaryEmail(company);
        bool hasSocial = ChamberMembershipController.HasSocialLinks(company);

        <div class="mb-3">
            <a href="@backToDirectoryUrl" class="text-decoration-none">
                <span aria-hidden="true">&larr;</span> Back to Directory
            </a>
        </div>

        <section class="bcc-company-detail container px-0">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8">
                    <div class="card border-0 rounded-4 overflow-hidden">

                        <div class="card-body p-4 p-lg-5">
                            <div class="d-flex flex-column align-items-center text-center">

                                @if (!string.IsNullOrWhiteSpace(logoUrl))
                                {
                                    <div class="bg-white rounded-4 p-3 mb-3" style="max-width: 320px;">
                                        <img src="@logoUrl" alt="Logo for @company.CompanyName" class="img-fluid" style="max-height: 320px;" loading="lazy" decoding="async" />
                                    </div>
                                }
                                else
                                {
                                    @* TODO: Replace placeholder logo with OpenContent setting/value *@
                                    <div class="bg-white rounded-4 p-3 mb-3" style="max-width: 320px;">
                                        <img src="/Portals/@portalId/Content/Members/burlingame-chamber-member-logo-placeholder-512x512.png"
                                            alt="Placeholder Logo for @company.CompanyName" class="img-fluid" style="max-height: 320px;" loading="lazy" decoding="async" />
                                    </div>
                                }

                                <h2 class="h2 fw-bold mb-1">@company.CompanyName</h2>

                                @if (!string.IsNullOrWhiteSpace(primaryCategory))
                                {
                                    <div class="h5 text-muted fw-semibold mb-2">@primaryCategory</div>
                                }

                                @if (company.IsFeatured)
                                {
                                    <div class="mb-3">
                                        <span class="badge rounded-pill text-bg-warning">
                                            <span class="fw-semibold">SPONSOR:</span> Featured Member
                                        </span>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(company.LongDescription))
                                {
                                    <div class="text-body text-start">
                                        <p class="mb-3">@company.LongDescription</p>
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(company.ShortDescription))
                                {
                                    <div class="text-body text-start">
                                        <p class="mb-3">@company.ShortDescription</p>
                                    </div>
                                }

                                <div class="d-flex flex-wrap gap-2 justify-content-center mt-2">
                                    @if (!string.IsNullOrWhiteSpace(company.WebsiteUrl))
                                    {
                                        <a class="btn btn-primary track-referral" href="@company.WebsiteUrl"
                                          target="_blank" rel="noopener" aria-label="Visit @company.CompanyName website">
                                            <i class="fa-solid fa-arrow-up-right-from-square me-2" aria-hidden="true"></i>Website
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(company.Phone))
                                    {
                                        <a class="btn btn-outline-secondary track-phone"
                                          href="tel:@company.Phone" aria-label="Call @company.CompanyName">
                                            <i class="fa-solid fa-phone me-2" aria-hidden="true"></i>Call
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(primaryEmail))
                                    {
                                        <a class="btn btn-outline-secondary track-email"
                                          href="mailto:@primaryEmail" aria-label="Email @company.CompanyName">
                                            <i class="fa-solid fa-envelope me-2" aria-hidden="true"></i>Email
                                        </a>
                                    }
                                </div>

                            </div>
                        </div>

            <!-- Social Channels Bar -->
            @if (hasSocial)
            {
                <div class="py-4">
                    <div class="bg-light border rounded-4 p-3">
                        <div class="d-flex flex-column flex-lg-row align-items-center justify-content-between gap-3">
                            <h3 class="h6 fw-semibold text-dark text-capitalize">Social Channels</h3>

                            <div class="d-flex flex-wrap justify-content-center gap-4">
                                @if (!string.IsNullOrWhiteSpace(company.LinkedInUrl))
                                {
                                    <a class="text-decoration-none track-social"
                                       href="@company.LinkedInUrl" target="_blank"
                                       rel="noopener noreferrer" aria-label="LinkedIn">
                                        <i class="fa-brands fa-linkedin me-2" aria-hidden="true"></i>LinkedIn
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(company.FacebookUrl))
                                {
                                    <a class="text-decoration-none track-social"
                                       href="@company.FacebookUrl" target="_blank"
                                       rel="noopener noreferrer" aria-label="Facebook">
                                        <i class="fa-brands fa-facebook me-2" aria-hidden="true"></i>Facebook
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(company.InstagramUrl))
                                {
                                    <a class="text-decoration-none track-social"
                                       href="@company.InstagramUrl" target="_blank"
                                       rel="noopener noreferrer" aria-label="Instagram">
                                        <i class="fa-brands fa-instagram me-2" aria-hidden="true"></i>Instagram
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(company.TikTokUrl))
                                {
                                    <a class="text-decoration-none track-social"
                                       href="@company.TikTokUrl" target="_blank"
                                       rel="noopener noreferrer" aria-label="TikTok">
                                        <i class="fa-brands fa-tiktok me-2" aria-hidden="true"></i>TikTok
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(company.TwitterUrl))
                                {
                                    <a class="text-decoration-none track-social"
                                       href="@company.TwitterUrl" target="_blank"
                                       rel="noopener noreferrer" aria-label="Twitter">
                                        <i class="fa-brands fa-twitter me-2" aria-hidden="true"></i>Twitter
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

                        
                    </div>
                </div>
            </div>

            <!-- Lower content: Contact & Business Info + Business Profile -->
            <div class="row justify-content-center mt-2">
              <div class="col-12 col-lg-8">

                  <div class="row g-4">
                      <div class="col-12 col-lg-6">
                          <!-- Contact & Business Info -->
                          <div class="pt-3">
                            <h3 class="small fw-bold mb-3">Contact &amp; Business Info</h3>

                            @if (!string.IsNullOrWhiteSpace(company.WebsiteUrl))
                            {
                                <div class="mb-4">
                                    <div class="fw-semibold text-dark">Website</div>
                                    <a href="@company.WebsiteUrl" target="_blank" rel="noopener" class="track-referral">@company.WebsiteUrl</a>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(company.Phone) || !string.IsNullOrWhiteSpace(primaryEmail))
                            {
                                <div class="mb-4">
                                    <div class="fw-semibold text-dark">Phone &amp; Email</div>
                                    <div>
                                        @if (!string.IsNullOrWhiteSpace(company.Phone))
                                        {
                                            <a href="tel:@company.Phone" class="track-phone">@company.Phone</a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(company.Phone) && !string.IsNullOrWhiteSpace(primaryEmail))
                                        {
                                            <span> • </span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(primaryEmail))
                                        {
                                            <a href="mailto:@primaryEmail" class="track-email">@primaryEmail</a>
                                        }
                                    </div>
                                </div>
                            }

                            @{
                                bool hasLocation =
                                    !string.IsNullOrWhiteSpace(company.Address1) ||
                                    !string.IsNullOrWhiteSpace(company.Address2) ||
                                    !string.IsNullOrWhiteSpace(company.City) ||
                                    !string.IsNullOrWhiteSpace(company.Region) ||
                                    !string.IsNullOrWhiteSpace(company.PostalCode);
                            }
                            @if (hasLocation)
                            {
                                <div class="mb-4">
                                    <div class="fw-semibold text-dark">Location</div>

                                    @if (!string.IsNullOrWhiteSpace(company.Address1))
                                    {
                                        <div>@company.Address1</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(company.Address2))
                                    {
                                        <div>@company.Address2</div>
                                    }

                                    @{
                                        var parts = new List<string>();
                                        if (!string.IsNullOrWhiteSpace(company.City)) { parts.Add(company.City); }
                                        if (!string.IsNullOrWhiteSpace(company.Region)) { parts.Add(company.Region); }
                                        if (!string.IsNullOrWhiteSpace(company.PostalCode)) { parts.Add(company.PostalCode); }
                                    }
                                    @if (parts.Count > 0)
                                    {
                                        <div>@string.Join(", ", parts)</div>
                                    }
                                </div>
                            }
                        </div>
                      </div>

                      <div class="col-12 col-lg-6">
                          <!-- Business Profile -->
                          <div class="pt-3">
                            <h3 class="small fw-bold mb-3">Business Profile</h3>

                            <div class="mb-4">
                                <div class="fw-semibold text-dark">Membership</div>
                                @if (company.MemberSinceYear.HasValue && company.MemberSinceYear.Value > 0)
                                {
                                    <div>Proud member since @company.MemberSinceYear.Value.</div>
                                }
                                else
                                {
                                    <div class="text-muted">Membership information not provided.</div>
                                }
                            </div>

                            <div class="mb-4">
                                <div class="fw-semibold text-dark">Category</div>
                                @{
                                    var cats = new List<string>();
                                    if (company.Categories != null)
                                    {
                                        foreach (var c in company.Categories)
                                        {
                                            if (c != null && !string.IsNullOrWhiteSpace(c.CategoryName))
                                            {
                                                cats.Add(c.CategoryName);
                                            }
                                        }
                                    }
                                }
                                @if (cats.Count > 0)
                                {
                                    <div>@string.Join(", ", cats)</div>
                                }
                                else if (!string.IsNullOrWhiteSpace(primaryCategory))
                                {
                                    <div>@primaryCategory</div>
                                }
                                else
                                {
                                    <div class="text-muted">No categories provided.</div>
                                }
                            </div>
                        </div>
                      </div>
                  </div>

              </div>
          </div>
        </section>

        <div class="mb-3">
            <a href="@backToDirectoryUrl" class="text-decoration-none">
                <span aria-hidden="true">&larr;</span> Back to Directory
            </a>
        </div> 

        @ChamberMembershipController.BuildCompanyJsonLd(
            company,
            companyDetailAbsoluteUrl,
            logoUrl,
            (company.Categories != null ? company.Categories.Select(c => c.CategoryName) : null)
        )
    }
}
else
{
    // Render existing filters + results grid + paging
    <section id="bcc-directory" class="bcc-directory py-4" aria-labelledby="bcc-directory-title">
        <div class="container">

            <header class="mb-0">
                <h1 id="bcc-directory-title" class="h3 mb-1">Business Directory</h1>
                <p class="text-muted mb-0">Search and explore Burlingame Chamber member businesses.</p>
            </header>

            <!-- FILTERS -->
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-4"
            role="search" aria-label="Business directory search and filters">

                <div class="d-flex flex-column flex-lg-row flex-lg-nowrap gap-2 align-items-stretch align-items-lg-end">

                <!-- Keyword -->
                <div class="flex-grow-1">
                    <label for="q" class="form-label fw-semibold mb-1">Keyword</label>
                    <input id="q"
                        type="search"
                        class="form-control"
                        placeholder="Search businesses"
                        value="@req.Query" />
                </div>

                <!-- Category -->
                <div style="min-width: 220px;">
                    <label for="cat" class="form-label fw-semibold mb-1">Category</label>
                    <select id="cat"
                            class="form-select"
                            aria-label="Filter by category">
                        <option value="">All categories</option>
                        @foreach (var c in categories)
                        {
                            if (c != null)
                            {
                                <option value="@c.Slug" @(c.Slug == req.CategorySlug ? "selected" : "")>@c.CategoryName</option>
                            }
                        }
                    </select>
                </div>

                <!-- Sort -->
                <div style="min-width: 180px;">
                    <label for="sort" class="form-label fw-semibold mb-1">Sort</label>
                    <select id="sort" class="form-select" aria-label="Sort results">
                        <option value="default" @(req.Sort == "default" ? "selected" : "")>Default (random)</option>
                        <option value="name" @(req.Sort == "name" ? "selected" : "")>Name (A–Z)</option>
                    </select>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-2" style="white-space: nowrap;">
                    <button type="button" id="bccDirSearchBtn" class="btn btn-primary">
                        Search
                    </button>

                    <button type="button" id="bccDirClearBtn" class="btn btn-outline-secondary">
                        Clear
                    </button>

                    <input type="hidden" id="pagesize" value="@pageSize" />
                </div>

            </div>

            </div>

            <!-- SUMMARY -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-muted small">
                    Showing <strong>@from</strong> to <strong>@to</strong> of <strong>@totalCount</strong>
                </div>
            </div>

            <!-- RESULTS -->
            @if (items.Count == 0)
            {
                <div class="alert alert-light border rounded-4">
                    No results found.
                </div>
            }
            else
            {
                <div class="row g-3" role="list">

                    @for (int i = 0; i < items.Count; i++)
                    {
                        CompanyDirectoryItem item = items[i];

                        string companyUrl = ChamberMembershipController.BuildCompanyDetailUrl(tabId, item.Slug, currentQuery);

                        string logoUrl = ChamberMembershipController.ResolveLogoUrl(portalId, item.LogoFileId, item.LogoUrl);

                        List<CategoryDto> companyCats = new List<CategoryDto>();
                        if (search != null && search.CategoriesByCompanyId != null)
                        {
                            List<CategoryDto> found = null;
                            if (search.CategoriesByCompanyId.TryGetValue(item.CompanyId, out found))
                            {
                                if (found != null)
                                {
                                    foreach (var fc in found)
                                    {
                                        if (fc != null)
                                        {
                                            companyCats.Add(fc);
                                        }
                                    }
                                }
                            }
                        }

                        <div class="col-12 col-md-6 col-lg-4" role="listitem">
                            <article class="card h-100 border-0 shadow-sm rounded-4">

                                <div class="ratio ratio-4x3 bg-white member-card-logo">
                                    @if (!string.IsNullOrWhiteSpace(logoUrl))
                                    {
                                        <a href="@companyUrl" class="savetime-directory">
                                            <img src="@logoUrl" alt="Logo for @item.CompanyName" class="w-100 h-100 object-fit-contain p-3" loading="lazy" decoding="async" />
                                        </a>
                                    }
                                    else
                                    {
                                        @* TODO: Replace placeholder logo with OpenContent setting/value *@
                                        <a href="@companyUrl" class="savetime-directory">
                                            <img src="/Portals/@portalId/Content/Members/burlingame-chamber-member-logo-placeholder-512x512.png" alt="Placeholder Logo for @item.CompanyName" class="w-100 h-100 object-fit-contain p-3" loading="lazy" decoding="async" />
                                        </a>
                                    }
                                </div>

                                <div class="card-body bg-light px-3">
                                    <h3 class="text-h5 mt-3 text-normalcase">
                                        <a href="@companyUrl" class="text-normalcase link-expanded savetime-directory">@item.CompanyName</a>
                                    </h3>

                                    @if (companyCats.Count > 0)
                                    {
                                    var catCount = 0;
                                        <div class="mb-2">
                                            @for (int c = 0; c < companyCats.Count && c < 3; c++)
                                            {
                                                catCount++;
                                                if(catCount == 1){
                                                <span class="badge bg-secondary">@companyCats[c].CategoryName</span>
                                                }
                                                else
                                                {
                                                <span class="badge text-bg-light border text-dark">@companyCats[c].CategoryName</span>
                                                }
                                            }
                                        </div>
                                    }

                                    <p>@item.ShortDescription</p>
                                </div>

                            </article>
                        </div>
                    }

                </div>
            }

            @if (totalPages > 1)
            {
                int current = page;

                // Show a small window of pages around the current page
                int window = 2; // current +/- 2
                int start = current - window;
                int end = current + window;

                start = DirectoryHelper.Clamp(start, 1, totalPages);
                end = DirectoryHelper.Clamp(end, 1, totalPages);

                // Ensure we still show up to (window*2 + 1) pages when near edges
                while ((end - start) < (window * 2) && (start > 1 || end < totalPages))
                {
                    if (start > 1)
                    {
                        start--;
                    }
                    else if (end < totalPages)
                    {
                        end++;
                    }
                    else
                    {
                        break;
                    }
                }

                <nav class="mt-4" aria-label="Directory results pages">
                    <ul class="pagination justify-content-center flex-wrap">

                        @{
                            bool prevDisabled = (current <= 1);
                            string prevClass = prevDisabled ? "page-item disabled" : "page-item";
                            string prevUrl = prevDisabled ? "#" : DirectoryHelper.BuildPageUrl(current - 1);
                        }
                        <li class="@prevClass">
                            <a class="page-link savetime-directory" href="@prevUrl" aria-label="Previous page">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        @if (start > 1)
                        {
                            <li class="page-item">
                                <a class="page-link savetime-directory" href="@DirectoryHelper.BuildPageUrl(1)">1</a>
                            </li>

                            if (start > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link" aria-hidden="true">…</span>
                                </li>
                            }
                        }

                        @for (int p = start; p <= end; p++)
                        {
                            bool isCurrent = (p == current);
                            string liClass = isCurrent ? "page-item active" : "page-item";
                            string url = DirectoryHelper.BuildPageUrl(p);

                            <li class="@liClass" aria-current="@(isCurrent ? "page" : "")">
                                <a class="page-link savetime-directory" href="@url">@p</a>
                            </li>
                        }

                        @if (end < totalPages)
                        {
                            if (end < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link" aria-hidden="true">…</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link savetime-directory" href="@DirectoryHelper.BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        @{
                            bool nextDisabled = (current >= totalPages);
                            string nextClass = nextDisabled ? "page-item disabled" : "page-item";
                            string nextUrl = nextDisabled ? "#" : DirectoryHelper.BuildPageUrl(current + 1);
                        }
                        <li class="@nextClass">
                            <a class="page-link savetime-directory" href="@nextUrl" aria-label="Next page">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>

                    </ul>
                </nav>
            }

        </div>
    </section>
    <script>
    (function () {
        "use strict";

        var COOKIE_NAME = "savetime-directory";
        var COOKIE_DAYS = 30; // ~1 month

        function getEl(id) {
            return document.getElementById(id);
        }

        function safe(fn) {
            try { fn(); } catch (e) { /* fail silently */ }
        }

        function setCookie(name, value, days) {
            safe(function () {
                var d = new Date();
                d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));

                var expires = "expires=" + d.toUTCString();
                var path = "path=/";
                var sameSite = "SameSite=Lax";
                var secure = (window.location && window.location.protocol === "https:") ? "Secure" : "";

                document.cookie = name + "=" + encodeURIComponent(value) + ";" + expires + ";" + path + ";" + sameSite + ";" + secure;
            });
        }

        function getCookie(name) {
            var value = null;

            safe(function () {
                var cookies = document.cookie ? document.cookie.split(";") : [];
                for (var i = 0; i < cookies.length; i++) {
                    var c = cookies[i].trim();
                    if (c.indexOf(name + "=") === 0) {
                        value = decodeURIComponent(c.substring((name + "=").length));
                        break;
                    }
                }
            });

            return value;
        }

        function prefersReducedMotion() {
            safe(function () { /* no-op wrapper */ });
            return !!(window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches);
        }

        function isElementInView(el) {
            if (!el || !el.getBoundingClientRect) return false;

            var r = el.getBoundingClientRect();

            // Consider it "in view" if top is within the first ~120px of viewport
            // or already above it (meaning user has scrolled past / near it).
            return (r.top <= 120 && r.bottom > 0);
        }

        function scrollToDirectoryIfNeeded() {
            safe(function () {
                var cookieVal = getCookie(COOKIE_NAME);

                // Only act when cookie is explicitly "1"
                if (cookieVal !== "1") return;

                // If user prefers reduced motion, jump (no smooth scroll)
                var behavior = prefersReducedMotion() ? "auto" : "smooth";

                var target = document.getElementById("bcc-directory") || document.getElementById("bcc-directory-title");
                if (!target) return;

                // If it's already in view, don't scroll
                if (isElementInView(target)) return;

                // Scroll after layout settles
                window.requestAnimationFrame(function () {
                    safe(function () {
                        target.scrollIntoView({ behavior: behavior, block: "start" });
                    });
                });
            });
        }

        function buildUrl() {
            var qEl = getEl("q");
            var catEl = getEl("cat");
            var sortEl = getEl("sort");
            var pageSizeEl = getEl("pagesize");

            var q = qEl ? qEl.value : "";
            var cat = catEl ? catEl.value : "";
            var sort = sortEl ? sortEl.value : "";
            var pagesize = pageSizeEl ? pageSizeEl.value : "";

            var parts = [];

            if (q && q.replace(/\s/g, "").length > 0) {
                parts.push("q=" + encodeURIComponent(q));
            }

            // Always reset to page 1 when searching
            parts.push("page=1");

            if (pagesize && pagesize.length > 0) {
                parts.push("pagesize=" + encodeURIComponent(pagesize));
            }

            if (cat && cat.length > 0) {
                parts.push("cat=" + encodeURIComponent(cat));
            }

            if (sort && sort.length > 0 && sort !== "default") {
                parts.push("sort=" + encodeURIComponent(sort));
            }

            var basePath = window.location.pathname;
            var qs = parts.join("&");

            return qs.length > 0 ? (basePath + "?" + qs) : basePath;
        }

        function doSearch() {
            // Mark them as "returning" before navigation
            setCookie(COOKIE_NAME, "1", COOKIE_DAYS);
            window.location.href = buildUrl();
        }

        function doClear() {
            // Optional: clearing search does NOT reset cookie by default
            // (they still likely want the skip-hero behavior next time)
            window.location.href = window.location.pathname;
        }

        // Wire up buttons
        var searchBtn = getEl("bccDirSearchBtn");
        if (searchBtn) {
            searchBtn.addEventListener("click", function () { doSearch(); });
        }

        var clearBtn = getEl("bccDirClearBtn");
        if (clearBtn) {
            clearBtn.addEventListener("click", function () { doClear(); });
        }

        // Pressing Enter in keyword input triggers search
        var qInput = getEl("q");
        if (qInput) {
            qInput.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    doSearch();
                }
            });
        }

        // Clicks on company links (or any other links you tag)
        // Use event delegation so it works even if markup changes later.
        document.addEventListener("click", function (e) {
            safe(function () {
                var el = e.target;

                // walk up to an anchor
                while (el && el !== document.body && el.tagName !== "A") {
                    el = el.parentElement;
                }

                if (!el || el.tagName !== "A") return;

                if (el.classList && el.classList.contains("savetime-directory")) {
                    setCookie(COOKIE_NAME, "1", COOKIE_DAYS);
                }
            });
        }, true);

        // After load, if cookie exists, scroll once (subtle)
        // Using window load helps ensure layout/images have settled.
        window.addEventListener("load", function () {
            scrollToDirectoryIfNeeded();
        });

    })();
    </script>
}

