@using System
@using System.Collections.Generic
@using Upendo.Libraries.RunsOnUpendoCore.Helpers
@inherits Satrabel.OpenContent.Components.OpenContentWebPage

@{
    TemplateHelper.HideAdminBorder(Model.Context.ModuleId, Model.Context.TabId);
    RegisterStyleSheet("template.css");

    var moduleAnchor = Model.ModuleAnchor != null ? Convert.ToString(Model.ModuleAnchor) : string.Empty;

    var heroTitle = Model.HeroTitle != null ? Convert.ToString(Model.HeroTitle) : string.Empty;
    var heroLead = Model.HeroLead != null ? Convert.ToString(Model.HeroLead) : string.Empty;
    var heroImage = Model.HeroImage != null ? Convert.ToString(Model.HeroImage) : string.Empty;
    var heroImageAlt = Model.HeroImageAlt != null ? Convert.ToString(Model.HeroImageAlt) : string.Empty;

    var backgroundColorClass = Model.Settings != null && Model.Settings.BackgroundColorClass != null
        ? Convert.ToString(Model.Settings.BackgroundColorClass)
        : string.Empty;

    var marginTop = Model.Settings != null && Model.Settings.MarginTop != null
        ? Convert.ToString(Model.Settings.MarginTop)
        : string.Empty;

    var marginBottom = Model.Settings != null && Model.Settings.MarginBottom != null
        ? Convert.ToString(Model.Settings.MarginBottom)
        : string.Empty;

    var paddingTop = Model.Settings != null && Model.Settings.PaddingTop != null
        ? Convert.ToString(Model.Settings.PaddingTop)
        : string.Empty;

    var paddingBottom = Model.Settings != null && Model.Settings.PaddingBottom != null
        ? Convert.ToString(Model.Settings.PaddingBottom)
        : string.Empty;

    var hasModuleAnchor = !string.IsNullOrWhiteSpace(moduleAnchor);
    var hasHeroTitle = !string.IsNullOrWhiteSpace(heroTitle);
    var hasHeroLead = !string.IsNullOrWhiteSpace(heroLead);
    var hasHeroImage = !string.IsNullOrWhiteSpace(heroImage);

    var resolvedImageAlt = !string.IsNullOrWhiteSpace(heroImageAlt) ? heroImageAlt : heroTitle;

    var breadcrumbItems = TemplateHelper.GetActiveTabBreadcrumbs(true);
    var hasBreadcrumbs = breadcrumbItems != null && breadcrumbItems.Count > 0;

    var sectionClass = "oc-inner-hero-breadcrumb position-relative";

    if (!string.IsNullOrWhiteSpace(backgroundColorClass))
    {
        sectionClass += " " + backgroundColorClass;
    }

    if (!string.IsNullOrWhiteSpace(marginTop))
    {
        sectionClass += " " + marginTop;
    }

    if (!string.IsNullOrWhiteSpace(marginBottom))
    {
        sectionClass += " " + marginBottom;
    }

    if (!string.IsNullOrWhiteSpace(paddingTop))
    {
        sectionClass += " " + paddingTop;
    }

    if (!string.IsNullOrWhiteSpace(paddingBottom))
    {
        sectionClass += " " + paddingBottom;
    }
}

@if (hasModuleAnchor)
{
    <div id="@moduleAnchor"></div>
}

<section class="@sectionClass">
    <div class="container-xxl">
        <div class="row align-items-center g-4 g-lg-5 oc-inner-hero-breadcrumb__row">
            <div class="col-12 col-lg-6 order-2 order-lg-1">
                <div class="oc-inner-hero-breadcrumb__content">

                    @if (hasBreadcrumbs)
                    {
                        <nav class="oc-inner-hero-breadcrumb__nav" aria-label="Breadcrumb">
                            <ol class="oc-inner-hero-breadcrumb__list list-unstyled mb-0"
                                itemscope
                                itemtype="https://schema.org/BreadcrumbList">

                                @for (var i = 0; i < breadcrumbItems.Count; i++)
                                {
                                    var item = breadcrumbItems[i];
                                    var isLast = item.IsCurrent;

                                    <li class="oc-inner-hero-breadcrumb__item"
                                        itemprop="itemListElement"
                                        itemscope
                                        itemtype="https://schema.org/ListItem">

                                        @if (!isLast && !string.IsNullOrWhiteSpace(item.Url))
                                        {
                                            <a href="@item.Url"
                                               class="oc-inner-hero-breadcrumb__link"
                                               itemprop="item">
                                                <span itemprop="name">@item.Text</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="oc-inner-hero-breadcrumb__current"
                                                  aria-current="page"
                                                  itemprop="name">@item.Text</span>
                                        }

                                        <meta itemprop="position" content="@item.Position" />
                                    </li>
                                }

                            </ol>
                        </nav>
                    }

                    @if (hasHeroTitle)
                    {
                        <h1 class="oc-inner-hero-breadcrumb__title">@heroTitle</h1>
                    }

                    @if (hasHeroLead)
                    {
                        <div class="oc-inner-hero-breadcrumb__lead">
                            <p>@heroLead</p>
                        </div>
                    }

                </div>
            </div>

            <div class="col-12 col-lg-6 order-1 order-lg-2">
                @if (hasHeroImage)
                {
                    <div class="oc-inner-hero-breadcrumb__media-wrap">
                        <div class="oc-inner-hero-breadcrumb__media shadow">
                            <img src="@heroImage"
                                 alt="@resolvedImageAlt"
                                 class="img-fluid oc-inner-hero-breadcrumb__image"
                                 loading="eager"
                                 decoding="async" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>