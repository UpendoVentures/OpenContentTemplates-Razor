  "type": "object",
  "properties": {
    "ModuleTitle": {
      "type": "string",
      "title": "Module Title"
    },
    "ModuleAnchor": {
      "type": "string",
      "title": "Module Anchor",
       "pattern": "^[a-zA-Z0-9\\-]+$"
    },
    "SectionEyebrow": {
      "type": "string",
      "title": "Section Eyebrow"
    },
    "SectionTitle": {
