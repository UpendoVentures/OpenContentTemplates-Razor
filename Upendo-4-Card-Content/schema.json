{
  "type": "object",
  "properties": {
    "ModuleTitle": {
      "type": "string",
      "title": "Module Title"
    },
    "ModuleAnchor": {
      "type": "string",
      "title": "Module Anchor",
       "pattern": "^[a-zA-Z0-9\\-]+$"
    },
    "Card1": {
      "type": "object",
      "title": "Card 1 - Left Column",
      "required": [
        "Title",
        "Description",
        "IconClass",
        "BorderColor",
        "IconColor"
      ],
      "properties": {
        "Title": {
          "type": "string",
          "title": "Title"
        },
        "Description": {
          "type": "string",
          "title": "Description"
        },
        "IconClass": {
          "type": "string",
          "title": "FontAwesome Icon Class",
          "default": "fa-solid fa-magnifying-glass-chart"
        },
        "BorderColor": {
          "type": "string",
          "title": "Top Border Color",
          "enum": [
            "border-primary",
            "border-secondary",
            "border-success",
            "border-danger",
            "border-warning",
            "border-info",
            "border-dark"
          ],
          "default": "border-info"
        },
        "IconColor": {
          "type": "string",
          "title": "Icon Color",
          "enum": [
            "text-primary",
            "text-secondary",
            "text-success",
            "text-danger",
            "text-warning",
            "text-info",
            "text-dark"
          ],
          "default": "text-info"
        }
      }
    },
