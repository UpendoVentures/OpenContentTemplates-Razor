@using System
@using Upendo.SkinObjects.OpenContentHelper.Helpers
@inherits Satrabel.OpenContent.Components.OpenContentWebPage

@{
    TemplateHelper.HideAdminBorder(Model.Context.ModuleId, Model.Context.TabId);
    RegisterStyleSheet("template.css");

    var moduleTitle = Model.ModuleTitle != null ? Convert.ToString(Model.ModuleTitle) : string.Empty;
    var moduleAnchor = Model.ModuleAnchor != null ? Convert.ToString(Model.ModuleAnchor) : string.Empty;

    var heading = Model.Heading != null ? Convert.ToString(Model.Heading) : string.Empty;
    var headingCssClass = Model.HeadingCssClass != null ? Convert.ToString(Model.HeadingCssClass) : string.Empty;
    var descriptionText = Model.DescriptionText != null ? Convert.ToString(Model.DescriptionText) : string.Empty;

    var primaryCtaButtonText = Model.PrimaryCtaButtonText != null ? Convert.ToString(Model.PrimaryCtaButtonText) : string.Empty;
    var primaryCtaButtonUrl = Model.PrimaryCtaButtonUrl != null ? Convert.ToString(Model.PrimaryCtaButtonUrl) : string.Empty;

    var secondaryCtaButtonText = Model.SecondaryCtaButtonText != null ? Convert.ToString(Model.SecondaryCtaButtonText) : string.Empty;
    var secondaryCtaButtonUrl = Model.SecondaryCtaButtonUrl != null ? Convert.ToString(Model.SecondaryCtaButtonUrl) : string.Empty;

    var marginTop = Model.Settings != null && Model.Settings.MarginTop != null
        ? Convert.ToString(Model.Settings.MarginTop)
        : string.Empty;

    var marginBottom = Model.Settings != null && Model.Settings.MarginBottom != null
        ? Convert.ToString(Model.Settings.MarginBottom)
        : string.Empty;

    var paddingTop = Model.Settings != null && Model.Settings.PaddingTop != null
        ? Convert.ToString(Model.Settings.PaddingTop)
        : string.Empty;

    var paddingBottom = Model.Settings != null && Model.Settings.PaddingBottom != null
        ? Convert.ToString(Model.Settings.PaddingBottom)
        : string.Empty;

    var backgroundColorClass = Model.Settings != null && Model.Settings.BackgroundColorClass != null
        ? Convert.ToString(Model.Settings.BackgroundColorClass)
        : string.Empty;

    var outerSectionClass = "oc-centered-cta-band";
    if (!string.IsNullOrWhiteSpace(backgroundColorClass)) { outerSectionClass += " " + backgroundColorClass; }
    if (!string.IsNullOrWhiteSpace(marginTop)) { outerSectionClass += " " + marginTop; }
    if (!string.IsNullOrWhiteSpace(marginBottom)) { outerSectionClass += " " + marginBottom; }
    if (!string.IsNullOrWhiteSpace(paddingTop)) { outerSectionClass += " " + paddingTop; }
    if (!string.IsNullOrWhiteSpace(paddingBottom)) { outerSectionClass += " " + paddingBottom; }

    var headingClass = "oc-ccb-heading";
    if (!string.IsNullOrWhiteSpace(headingCssClass)) { headingClass += " " + headingCssClass; }

    var hasPrimaryCta = !string.IsNullOrWhiteSpace(primaryCtaButtonText) && !string.IsNullOrWhiteSpace(primaryCtaButtonUrl);
    var hasSecondaryCta = !string.IsNullOrWhiteSpace(secondaryCtaButtonText) && !string.IsNullOrWhiteSpace(secondaryCtaButtonUrl);

    var ariaLabel = !string.IsNullOrWhiteSpace(moduleTitle)
        ? moduleTitle
        : (!string.IsNullOrWhiteSpace(heading) ? heading : "Call to action");
}

@if (!string.IsNullOrWhiteSpace(moduleAnchor))
{
    <div id="@moduleAnchor"></div>
}

@if (!string.IsNullOrWhiteSpace(heading) && !string.IsNullOrWhiteSpace(descriptionText) && hasPrimaryCta)
{
    <section class="@outerSectionClass" aria-label="@ariaLabel">
        <div class="container-fluid px-0">
            <div class="container-xxl px-3 px-md-4">
                <div class="oc-ccb-inner text-center mx-auto py-4 py-md-5">
                    <h2 class="@headingClass">
                        @Html.Raw(heading)
                    </h2>

                    <div class="oc-ccb-description mx-auto">
                        @Html.Raw(descriptionText)
                    </div>

                    <div class="oc-ccb-actions d-flex flex-column flex-sm-row justify-content-center align-items-stretch align-items-sm-center gap-3">
                        <a href="@primaryCtaButtonUrl" class="btn btn-primary rounded-pill oc-ccb-btn oc-ccb-btn-primary track-cta">
                            @Html.Raw(primaryCtaButtonText)
                        </a>

                        @if (hasSecondaryCta)
                        {
                            <a href="@secondaryCtaButtonUrl" class="btn btn-secondary rounded-pill oc-ccb-btn oc-ccb-btn-secondary track-cta">
                                @Html.Raw(secondaryCtaButtonText)
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}