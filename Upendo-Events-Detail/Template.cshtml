    </div>
    <div class="alert alert-info m-4" role="alert">
        <h6 class="fw-bold mb-2">Raw Request Details</h6>
        <ul class="mb-0 small">
            <li><strong>RawUrl:</strong> @(httpRequest != null ? httpRequest.RawUrl : "[null]")</li>
            <li><strong>Url.AbsoluteUri:</strong> @(httpRequest != null && httpRequest.Url != null ? httpRequest.Url.AbsoluteUri : "[null]")</li>
            <li><strong>Url.AbsolutePath:</strong> @(httpRequest != null && httpRequest.Url != null ? httpRequest.Url.AbsolutePath : "[null]")</li>
            <li><strong>Url.PathAndQuery:</strong> @(httpRequest != null && httpRequest.Url != null ? httpRequest.Url.PathAndQuery : "[null]")</li>
