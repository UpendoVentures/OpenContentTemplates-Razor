@using System
@using System.Collections.Generic
@using System.Globalization
@using System.Web
@using Upendo.OpenContentHelper.Features.Events
@using Upendo.OpenContentHelper.Features.Events.Helpers
@using Upendo.OpenContentHelper.Features.Events.Models
@using Upendo.SkinObjects.OpenContentHelper.Helpers
@inherits Satrabel.OpenContent.Components.OpenContentWebPage

@functions {
    public string GetSafeString(object value)
    {
        return value == null ? string.Empty : Convert.ToString(value);
    }

    public bool GetBoolValue(object value, bool defaultValue)
    {
        if (value == null)
        {
            return defaultValue;
        }

        bool parsed;
        if (bool.TryParse(Convert.ToString(value), out parsed))
        {
            return parsed;
        }

        return defaultValue;
    }

    public int GetIntValue(object value, int defaultValue)
    {
        if (value == null)
        {
            return defaultValue;
        }

        int parsed;
        if (int.TryParse(Convert.ToString(value), out parsed))
        {
            return parsed;
        }

        return defaultValue;
    }
}

@{
    TemplateHelper.HideAdminBorder(Dnn.Module.ModuleID, Dnn.Module.TabID);
    RegisterStyleSheet("template.css");

    int portalId = -1;
    if (Dnn != null && Dnn.Portal != null)
    {
        portalId = Dnn.Portal.PortalId;
    }

    string listPagePath = EventConstants.EventListPageRoute;
    string detailPagePath = EventConstants.EventDetailPageRoute;
    int relatedEventCount = 3;
    bool showRelatedEvents = true;
    bool showAudiences = true;
    bool showFeatures = true;

    if (Model != null)
    {
        if (Model.ListPagePath != null)
        {
            listPagePath = GetSafeString(Model.ListPagePath);
        }

        if (Model.DetailPagePath != null)
        {
            detailPagePath = GetSafeString(Model.DetailPagePath);
        }

        if (Model.RelatedEventCount != null)
        {
            relatedEventCount = GetIntValue(Model.RelatedEventCount, 3);
        }

        if (Model.ShowRelatedEvents != null)
        {
            showRelatedEvents = GetBoolValue(Model.ShowRelatedEvents, true);
        }

        if (Model.ShowAudiences != null)
        {
            showAudiences = GetBoolValue(Model.ShowAudiences, true);
        }

        if (Model.ShowFeatures != null)
        {
            showFeatures = GetBoolValue(Model.ShowFeatures, true);
        }
    }

    HttpRequest httpRequest = HttpContext.Current != null ? HttpContext.Current.Request : null;
    string slug = EventSlugHelper.GetSlugFromRequest(httpRequest, detailPagePath);

    var errorMessage = string.Empty;
    EventDetailViewModel vm = null; 
    try
    {
        vm = EventFacade.GetDetailViewModel(
            portalId,
            slug,
            listPagePath,
            detailPagePath,
            relatedEventCount);
    }
    catch (Exception ex)
    {
        errorMessage = ex.Message;
    }

    bool hasEvent = vm != null && vm.EventFound && vm.Event != null;

    bool showEdit = (Model.Context.IsEditMode || TemplateHelper.CurrentUserCanEdit());
}

@if(Model.Context.IsEditMode)
{
    if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger m-4" role="alert">
            <h6 class="fw-bold mb-2">Error Loading Event Details</h6>
            <p class="mb-0text-muted">(Use the Event Viewer for more information)</p> 
        </div>
    }
    <div class="alert alert-warning m-4" role="alert">
        <h6 class="fw-bold mb-2">Troubleshooting Details</h6>
        <p class="mb-0">
            <strong>Portal ID:</strong> @portalId | 
            <strong>Slug:</strong> @slug | 
            <strong>List Page Path:</strong> @listPagePath | 
            <strong>Detail Page Path:</strong> @detailPagePath | 
            <strong>Related Event Count:</strong> @relatedEventCount
        </p>        
    </div>
    <!--
    <div class="alert alert-info m-4" role="alert">
        <h6 class="fw-bold mb-2">Slug Debug</h6>
        <p class="mb-1"><strong>RawUrl:</strong> @(httpRequest != null ? httpRequest.RawUrl : "[null]")</p>
        <p class="mb-1"><strong>Extracted Slug:</strong> @slug</p>
        <p class="mb-0"><strong>Slug Length:</strong> @(string.IsNullOrWhiteSpace(slug) ? 0 : slug.Length)</p>
    </div>
    <div class="alert alert-info m-4" role="alert">
        <h6 class="fw-bold mb-2">Raw Request Details</h6>
        <ul class="mb-0 small">
            <li><strong>RawUrl:</strong> @(httpRequest != null ? httpRequest.RawUrl : "[null]")</li>
            <li><strong>Url.AbsoluteUri:</strong> @(httpRequest != null && httpRequest.Url != null ? httpRequest.Url.AbsoluteUri : "[null]")</li>
            <li><strong>Url.AbsolutePath:</strong> @(httpRequest != null && httpRequest.Url != null ? httpRequest.Url.AbsolutePath : "[null]")</li>
            <li><strong>Url.PathAndQuery:</strong> @(httpRequest != null && httpRequest.Url != null ? httpRequest.Url.PathAndQuery : "[null]")</li>
            <li><strong>Path:</strong> @(httpRequest != null ? httpRequest.Path : "[null]")</li>
            <li><strong>PathInfo:</strong> @(httpRequest != null ? httpRequest.PathInfo : "[null]")</li>
            <li><strong>FilePath:</strong> @(httpRequest != null ? httpRequest.FilePath : "[null]")</li>
            <li><strong>AppRelativeCurrentExecutionFilePath:</strong> @(httpRequest != null ? httpRequest.AppRelativeCurrentExecutionFilePath : "[null]")</li>
            <li><strong>CurrentExecutionFilePath:</strong> @(httpRequest != null ? httpRequest.CurrentExecutionFilePath : "[null]")</li>
        </ul>
    </div>
    -->
}

@if (!hasEvent)
{
    <div class="container my-5">
        <div class="p-4 p-lg-5 rounded-4 border bg-light text-center">
            <div class="mb-3">
                <i class="fa-regular fa-calendar-xmark fa-2x text-muted" aria-hidden="true"></i>
            </div>
            <h1 class="h3 mb-3">@(vm != null ? vm.FriendlyMessageTitle : "We Couldn’t Find That Event")</h1>
            <p class="text-muted mb-4">@(vm != null ? vm.FriendlyMessageBody : "The event you were looking for may have been removed, renamed, or the link may be incomplete.")</p>
            <a href="@EventPageUrlHelper.BuildListPageUrl(listPagePath)" class="btn btn-primary">
                View All Events
            </a>
        </div>
    </div>

    return;
}

@{
    EventDetailDto evt = vm.Event;

    string relativeDate = EventFormattingHelper.GetDisplayDate(evt);
    string absoluteDate = EventFormattingHelper.GetAbsoluteDisplayDate(evt.StartDateTimeUtc);
    string shortDisplayDate = EventFormattingHelper.GetShortDisplayDate(evt.StartDateTimeUtc);
    string displayTime = EventFormattingHelper.GetDisplayTime(evt);
    string displayPrice = EventFormattingHelper.GetDisplayPrice(evt);

    string imageUrl = !string.IsNullOrWhiteSpace(evt.HeroImageUrl)
        ? evt.HeroImageUrl
        : evt.ListImageUrl;

    string locationText = string.Empty;
    if (evt.Venue != null)
    {
        if (!string.IsNullOrWhiteSpace(evt.Venue.PublicLocationText))
        {
            locationText = evt.Venue.PublicLocationText;
        }
        else if (!string.IsNullOrWhiteSpace(evt.Venue.VenueName))
        {
            locationText = evt.Venue.VenueName;
        }
        else
        {
            locationText = string.Concat(
                evt.Venue.City,
                !string.IsNullOrWhiteSpace(evt.Venue.Region)
                    ? string.Concat(", ", evt.Venue.Region)
                    : string.Empty);
        }
    }

    bool hasMetaBlock = !string.IsNullOrWhiteSpace(absoluteDate)
        || !string.IsNullOrWhiteSpace(displayTime)
        || !string.IsNullOrWhiteSpace(locationText);

    bool hasTags = evt.Tags != null && evt.Tags.Count > 0;
    bool hasFeatures = showFeatures && evt.Features != null && evt.Features.Count > 0;
    bool hasAudiences = showAudiences && evt.Audiences != null && evt.Audiences.Count > 0;
    bool hasRelated = showRelatedEvents && evt.RelatedEvents != null && evt.RelatedEvents.Count > 0;
    string detailUrl = TemplateHelper.BuildAbsoluteUrl(EventPageUrlHelper.BuildDetailPageUrl(detailPagePath, evt.Slug));
    string canonicalUrl = !string.IsNullOrWhiteSpace(evt.CanonicalUrl)
        ? TemplateHelper.BuildAbsoluteUrl(evt.CanonicalUrl)
        : detailUrl;
    string imageAbsoluteUrl = TemplateHelper.BuildAbsoluteUrl(imageUrl);
    string imageAltText = EventFormattingHelper.GetImageAltText(evt);
    string venueAddressText = evt.Venue != null ? EventFormattingHelper.GetVenueAddressText(evt.Venue) : string.Empty;
}
<main id="main-content" class="container my-4 my-lg-5 event-detail-shell">

    <div class="mb-4">
        <a href="@EventPageUrlHelper.BuildListPageUrl(listPagePath)" class="event-back-link small" aria-label="Back to all events">
            <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
            Back to Events
        </a>
    </div>

    <section class="event-hero mb-5">
        <div class="row g-4 g-lg-5 align-items-start">

            <div class="col-12 col-lg-7">

                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if (evt.IsUpcoming)
                    {
                        <span class="badge rounded-pill text-bg-primary">Upcoming</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill text-bg-secondary">Past</span>
                    }

                    @if (!string.IsNullOrWhiteSpace(evt.CategoryName))
                    {
                        <span class="category-chip">@evt.CategoryName</span>
                    }

                    @if (hasTags)
                    {
                        <nav aria-label="Tags for this event" class="d-flex flex-wrap gap-2">
                            @foreach (var tag in evt.Tags)
                            {
                                <a href="@EventPageUrlHelper.BuildListPageUrl(listPagePath)?tag=@HttpUtility.UrlEncode(tag.Slug)" class="tag-chip">
                                    #@tag.TagName
                                </a>
                            }
                        </nav>
                    }
                </div>

                <h1 class="display-5 fw-bold mb-3">@evt.Title</h1>

                @if (showEdit){
                    <a href="@EventUrlHelper.GetEditUrl(evt.EventId)" class="btn btn-outline-secondary btn-sm mb-3">
                        <i class="fa-solid fa-pen-to-square me-1" aria-hidden="true"></i>
                        Edit Event
                    </a>
                }

                @if (!string.IsNullOrWhiteSpace(evt.ShortSummary))
                {
                    <p class="event-lead mb-4">@evt.ShortSummary</p>
                }

                @if (hasMetaBlock)
                {
                    <div class="event-meta-grid mb-4">

                        @if (!string.IsNullOrWhiteSpace(absoluteDate))
                        {
                            <div class="event-meta-item">
                                <div class="event-meta-icon">
                                    <i class="fa-regular fa-calendar" aria-hidden="true"></i>
                                </div>
                                <div>
                                    <div class="event-meta-label">Date</div>
                                    <div>
                                        <time datetime="@EventFormattingHelper.GetIsoDateTime(evt.StartDateTimeUtc)">@absoluteDate</time>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(relativeDate))
                                    {
                                        <div class="small text-secondary">@relativeDate</div>
                                    }
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(displayTime))
                        {
                            <div class="event-meta-item">
                                <div class="event-meta-icon">
                                    <i class="fa-regular fa-clock" aria-hidden="true"></i>
                                </div>
                                <div>
                                    <div class="event-meta-label">Time</div>
                                    <div>
                                        <span class="visually-hidden">Time: </span>
                                        @displayTime
                                    </div>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(locationText))
                        {
                            <div class="event-meta-item">
                                <div class="event-meta-icon">
                                    <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                                </div>
                                <div>
                                    <div class="event-meta-label">Location</div>
                                    <div>
                                        <span class="visually-hidden">Location: </span>
                                        @locationText
                                    </div>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(displayPrice))
                        {
                            <div class="event-meta-item">
                                <div class="event-meta-icon">
                                    <i class="fa-solid fa-ticket" aria-hidden="true"></i>
                                </div>
                                <div>
                                    <div class="event-meta-label">Price</div>
                                    <div>@displayPrice</div>
                                </div>
                            </div>
                        }

                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(evt.RegistrationUrl) || !string.IsNullOrWhiteSpace(vm.IcsDownloadUrl))
                {
                    <div class="event-cta-row">
                        @if (!string.IsNullOrWhiteSpace(evt.RegistrationUrl))
                        {
                            <a href="@evt.RegistrationUrl"
                               class="btn btn-primary"
                               target="_blank"
                               rel="noopener noreferrer">
                                @(string.IsNullOrWhiteSpace(evt.RegistrationButtonText) ? "Register" : evt.RegistrationButtonText)
                            </a>
                        }

                        @if (!string.IsNullOrWhiteSpace(vm.IcsDownloadUrl))
                        {
                            <a href="@vm.IcsDownloadUrl" class="btn btn-outline-secondary">
                                Add to Calendar
                            </a>
                        }
                    </div>
                }

            </div>

            <div class="col-12 col-lg-5">
                @if (!string.IsNullOrWhiteSpace(imageUrl))
                {
                    <div class="event-hero-image-wrap">
                        <img src="@imageUrl" alt="@imageAltText" class="event-hero-image" loading="eager" decoding="async" />
                    </div>
                }
            </div>

        </div>
    </section>

    <section>
        <div class="row g-4 g-lg-5">

            <div class="col-12 col-lg-8">

                @if (!string.IsNullOrWhiteSpace(evt.FullDescription))
                {
                    <article class="mb-5">
                        <h2 class="h3 mb-3">Event Description</h2>
                        <div class="event-body-copy">
                            @Html.Raw(evt.FullDescription)
                        </div>
                    </article>
                }

                @if (hasFeatures)
                {
                    <article class="mb-5">
                        <h2 class="h3 mb-3">What to Expect</h2>

                        <div class="row g-3">
                            @foreach (var feature in evt.Features)
                            {
                                <div class="col-12 col-md-6">
                                    <div class="card event-feature-card border-0">
                                        <div class="card-body">
                                            @if (!string.IsNullOrWhiteSpace(feature.Title))
                                            {
                                                <h3 class="h6 mb-2">@feature.Title</h3>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(feature.Description))
                                            {
                                                <p class="mb-0 text-secondary">@feature.Description</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </article>
                }

                @if (hasAudiences)
                {
                    <article class="mb-5">
                        <h2 class="h3 mb-3">Who It’s For</h2>

                        <div class="row g-3">
                            @foreach (var audience in evt.Audiences)
                            {
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="card event-audience-card border-0">
                                        <div class="card-body">
                                            @if (!string.IsNullOrWhiteSpace(audience.AudienceTitle))
                                            {
                                                <h3 class="h6 mb-2">@audience.AudienceTitle</h3>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(audience.AudienceDescription))
                                            {
                                                <p class="mb-0 text-secondary">@audience.AudienceDescription</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </article>
                }

                @if (hasRelated)
                {
                    <section class="event-section-divider" aria-labelledby="related-events-heading">
                        <h2 id="related-events-heading" class="h3 mb-4">Related Events</h2>

                        <div class="row g-4">
                            @foreach (var rel in evt.RelatedEvents)
                            {
                                string relUrl = EventUrlHelper.GetDetailUrl(rel, vm.DetailPagePath);

                                <div class="col-12 col-md-6 col-xl-4">
                                    <article class="card event-related-card border-0">
                                        @if (!string.IsNullOrWhiteSpace(rel.ListImageUrl))
                                        {
                                            <a href="@relUrl" aria-label="View related event @rel.Title">
                                                <img src="@rel.ListImageUrl" alt="@(string.IsNullOrWhiteSpace(rel.ImageAltText) ? rel.Title : rel.ImageAltText)" 
                                                    class="card-img-top" loading="lazy" decoding="async" />
                                            </a>
                                        }

                                        <div class="card-body">
                                            @if (!string.IsNullOrWhiteSpace(rel.CategoryName))
                                            {
                                                <div class="small text-uppercase text-secondary fw-bold mb-2">@rel.CategoryName</div>
                                            }

                                            <h3 class="h5 mb-2">
                                                <a href="@relUrl" class="text-decoration-none" aria-label="View related event @rel.Title">@rel.Title</a>
                                            </h3>

                                            @{
                                                string relAbsoluteDate = EventFormattingHelper.GetShortDisplayDate(rel.StartDateTimeUtc);
                                                string relRelativeDate = EventFormattingHelper.GetDisplayDate(rel);
                                            }
                                            <div class="small text-secondary">
                                                <time datetime="@EventFormattingHelper.GetIsoDateTime(rel.StartDateTimeUtc)">@relAbsoluteDate</time>
                                                @if (!string.IsNullOrWhiteSpace(relRelativeDate))
                                                {
                                                    <span> - @relRelativeDate</span>
                                                }
                                            </div>
                                        </div>
                                    </article>
                                </div>
                            }
                        </div>
                    </section>
                }

            </div>

            <aside class="col-12 col-lg-4">

                <div class="event-detail-card mb-4">
                    <h2 class="h5 mb-3">Key Details</h2>

                    <ul class="event-key-details-list">

                        @if (!string.IsNullOrWhiteSpace(absoluteDate))
                        {
                            <li>
                                <div class="small text-uppercase text-secondary fw-bold">Date</div>
                                <div>
                                    <time datetime="@EventFormattingHelper.GetIsoDateTime(evt.StartDateTimeUtc)">@absoluteDate</time>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(relativeDate))
                                {
                                    <div class="small text-secondary">@relativeDate</div>
                                }
                            </li>
                        }

                        @if (!string.IsNullOrWhiteSpace(displayTime))
                        {
                            <li>
                                <div class="small text-uppercase text-secondary fw-bold">Time</div>
                                <div>@displayTime</div>
                            </li>
                        }

                        @if (!string.IsNullOrWhiteSpace(locationText))
                        {
                            <li>
                                <div class="small text-uppercase text-secondary fw-bold">Location</div>
                                <div>@locationText</div>
                            </li>
                        }

                        @if (!string.IsNullOrWhiteSpace(displayPrice))
                        {
                            <li>
                                <div class="small text-uppercase text-secondary fw-bold">Price</div>
                                <div>@displayPrice</div>
                            </li>
                        }

                    </ul>

                    @if (!string.IsNullOrWhiteSpace(evt.RegistrationUrl) || !string.IsNullOrWhiteSpace(vm.IcsDownloadUrl))
                    {
                        <div class="d-grid gap-2 mt-4">
                            @if (!string.IsNullOrWhiteSpace(evt.RegistrationUrl))
                            {
                                <a href="@evt.RegistrationUrl" class="btn btn-primary" target="_blank" rel="noopener noreferrer"
                                    aria-label="@(string.IsNullOrWhiteSpace(evt.RegistrationButtonText) ? "Register for " + evt.Title : evt.RegistrationButtonText + " for " + evt.Title)">
                                        @(string.IsNullOrWhiteSpace(evt.RegistrationButtonText) ? "Register" : evt.RegistrationButtonText)
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(vm.IcsDownloadUrl))
                            {
                                <a href="@vm.IcsDownloadUrl" class="btn btn-outline-secondary" aria-label="Add @evt.Title to your calendar">
                                    Add to Calendar
                                </a>
                            }
                        </div>
                    }
                </div>

                @if (evt.Organizer != null && !string.IsNullOrWhiteSpace(evt.Organizer.OrganizerName))
                {
                    <div class="event-detail-card mb-4">
                        <h2 class="h5 mb-3">Organizer</h2>

                        <div class="d-flex align-items-center gap-3">
                            <div class="event-organizer-avatar">
                                @TemplateHelper.GetInitials(evt.Organizer.OrganizerName)
                            </div>

                            <div>
                                <div class="fw-semibold">@evt.Organizer.OrganizerName</div>

                                @if (!string.IsNullOrWhiteSpace(evt.Organizer.WebsiteUrl))
                                {
                                    <a href="@evt.Organizer.WebsiteUrl" target="_blank" rel="noopener noreferrer"
                                        class="small text-decoration-none" aria-label="Visit the website for @evt.Organizer.OrganizerName">
                                        Visit Website
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }

            </aside>

        </div>
    </section>

    <script type="application/ld+json">
    {
        "@Html.Raw("@")context": "https://schema.org",
        "@Html.Raw("@")type": "Event",
        "name": "@HttpUtility.JavaScriptStringEncode(evt.Title)",
        "url": "@HttpUtility.JavaScriptStringEncode(canonicalUrl)",
        "description": "@HttpUtility.JavaScriptStringEncode(!string.IsNullOrWhiteSpace(evt.SeoDescription) ? evt.SeoDescription : (!string.IsNullOrWhiteSpace(evt.ShortSummary) ? evt.ShortSummary : evt.Title))",
        "startDate": "@EventFormattingHelper.GetIsoDateTime(evt.StartDateTimeUtc)"@(!string.IsNullOrWhiteSpace(EventFormattingHelper.GetIsoDateTimeNullable(evt.EndDateTimeUtc)) ? "," : "")
        @if (!string.IsNullOrWhiteSpace(EventFormattingHelper.GetIsoDateTimeNullable(evt.EndDateTimeUtc)))
        {
        <text>
        "endDate": "@EventFormattingHelper.GetIsoDateTimeNullable(evt.EndDateTimeUtc)",
        </text>
        }
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "eventStatus": "@(evt.IsUpcoming ? "https://schema.org/EventScheduled" : "https://schema.org/EventCompleted")",
        "image": [
            "@HttpUtility.JavaScriptStringEncode(imageAbsoluteUrl)"
        ]@((evt.Venue != null || evt.Organizer != null || evt.IsFree || evt.PriceAmount.HasValue) ? "," : "")
        @if (evt.Venue != null)
        {
        <text>
        "location": {
            "@Html.Raw("@")type": "Place",
            "name": "@HttpUtility.JavaScriptStringEncode(EventFormattingHelper.GetBestLocationText(evt))"@(!string.IsNullOrWhiteSpace(venueAddressText) || evt.Venue.Latitude.HasValue || evt.Venue.Longitude.HasValue ? "," : "")
            @if (!string.IsNullOrWhiteSpace(venueAddressText))
            {
        <text>
            "address": {
            "@Html.Raw("@")type": "PostalAddress",
            "streetAddress": "@HttpUtility.JavaScriptStringEncode(string.Join(", ", new[] { evt.Venue.AddressLine1, evt.Venue.AddressLine2 }.Where(x => !string.IsNullOrWhiteSpace(x))))",
            "addressLocality": "@HttpUtility.JavaScriptStringEncode(evt.Venue.City)",
            "addressRegion": "@HttpUtility.JavaScriptStringEncode(evt.Venue.Region)",
            "postalCode": "@HttpUtility.JavaScriptStringEncode(evt.Venue.PostalCode)",
            "addressCountry": "@HttpUtility.JavaScriptStringEncode(evt.Venue.CountryCode)"
            }@(evt.Venue.Latitude.HasValue || evt.Venue.Longitude.HasValue ? "," : "")
        </text>
            }
            @if (evt.Venue.Latitude.HasValue && evt.Venue.Longitude.HasValue)
            {
        <text>
            "geo": {
            "@Html.Raw("@")type": "GeoCoordinates",
            "latitude": @evt.Venue.Latitude.Value.ToString(CultureInfo.InvariantCulture),
            "longitude": @evt.Venue.Longitude.Value.ToString(CultureInfo.InvariantCulture)
            }
        </text>
            }
        }@(evt.Organizer != null || evt.IsFree || evt.PriceAmount.HasValue ? "," : "")
        </text>
        }
        @if (evt.Organizer != null && !string.IsNullOrWhiteSpace(evt.Organizer.OrganizerName))
        {
        <text>
        "organizer": {
            "@Html.Raw("@")type": "Organization",
            "name": "@HttpUtility.JavaScriptStringEncode(evt.Organizer.OrganizerName)"@(!string.IsNullOrWhiteSpace(evt.Organizer.WebsiteUrl) ? "," : "")
            @if (!string.IsNullOrWhiteSpace(evt.Organizer.WebsiteUrl))
            {
        <text>
            "url": "@HttpUtility.JavaScriptStringEncode(evt.Organizer.WebsiteUrl)"
        </text>
            }
        }@((evt.IsFree || evt.PriceAmount.HasValue) ? "," : "")
        </text>
        }
        @if (evt.IsFree || evt.PriceAmount.HasValue)
        {
        <text>
        "offers": {
            "@Html.Raw("@")type": "Offer",
            "url": "@HttpUtility.JavaScriptStringEncode(!string.IsNullOrWhiteSpace(evt.RegistrationUrl) ? evt.RegistrationUrl : canonicalUrl)",
            "availability": "https://schema.org/InStock",
            "priceCurrency": "@HttpUtility.JavaScriptStringEncode(!string.IsNullOrWhiteSpace(evt.PriceCurrencyCode) ? evt.PriceCurrencyCode : "USD")",
            "price": "@(evt.IsFree ? "0" : (evt.PriceAmount.HasValue ? evt.PriceAmount.Value.ToString(CultureInfo.InvariantCulture) : "0"))"
        }
        </text>
        }
    }
    </script>

</main>
