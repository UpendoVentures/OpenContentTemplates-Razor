@using System
@using System.Collections.Generic
@using System.Web
@using Upendo.OpenContentHelper.Features.Events
@using Upendo.OpenContentHelper.Features.Events.Helpers
@using Upendo.OpenContentHelper.Features.Events.Models
@inherits Satrabel.OpenContent.Components.OpenContentWebPage

@functions {

    public string BuildUrl(EventListRequest request, string categorySlug)
    {
        var query = HttpUtility.ParseQueryString(string.Empty);

        bool isUpcoming = true;
        if (request != null)
        {
            isUpcoming = request.IsUpcoming;
        }

        query["upcoming"] = isUpcoming ? "true" : "false";

        if (request != null && !string.IsNullOrWhiteSpace(request.TagSlug))
        {
            query["tag"] = request.TagSlug;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.OrganizerSlug))
        {
            query["organizer"] = request.OrganizerSlug;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.Keyword))
        {
            query["q"] = request.Keyword;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.SortBy))
        {
            query["sort"] = request.SortBy;
        }

        if (!string.IsNullOrWhiteSpace(categorySlug))
        {
            query["category"] = categorySlug;
        }

        string qs = query.ToString();
        return string.IsNullOrWhiteSpace(qs) ? "?" : "?" + qs;
    }

    public string BuildPageUrl(EventListRequest request, int pageNumber)
    {
        var query = HttpUtility.ParseQueryString(string.Empty);

        bool isUpcoming = true;
        if (request != null)
        {
            isUpcoming = request.IsUpcoming;
        }

        query["upcoming"] = isUpcoming ? "true" : "false";

        if (request != null && !string.IsNullOrWhiteSpace(request.CategorySlug))
        {
            query["category"] = request.CategorySlug;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.TagSlug))
        {
            query["tag"] = request.TagSlug;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.OrganizerSlug))
        {
            query["organizer"] = request.OrganizerSlug;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.Keyword))
        {
            query["q"] = request.Keyword;
        }

        if (request != null && !string.IsNullOrWhiteSpace(request.SortBy))
        {
            query["sort"] = request.SortBy;
        }

        if (pageNumber > 1)
        {
            query["page"] = pageNumber.ToString();
        }

        string qs = query.ToString();
        return string.IsNullOrWhiteSpace(qs) ? "?" : "?" + qs;
    }

    public string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        var parts = name.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 1)
        {
            return parts[0].Substring(0, 1).ToUpperInvariant();
        }

        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpperInvariant();
    }
}

@{
    int portalId = -1;
    if (Dnn != null && Dnn.Portal != null)
    {
        portalId = Dnn.Portal.PortalId;
    }

    string detailBasePath = "/events";
    int defaultPageSize = 10;
    bool showTopCategories = true;
    bool showTopTags = true;
    bool showTopOrganizers = true;

    if (Model != null)
    {
        if (Model.DetailBasePath != null)
        {
            detailBasePath = Convert.ToString(Model.DetailBasePath);
        }

        if (Model.DefaultPageSize != null)
        {
            int parsedPageSize;
            if (int.TryParse(Convert.ToString(Model.DefaultPageSize), out parsedPageSize) && parsedPageSize > 0)
            {
                defaultPageSize = parsedPageSize;
            }
        }

        if (Model.ShowTopCategories != null)
        {
            bool parsed;
            if (bool.TryParse(Convert.ToString(Model.ShowTopCategories), out parsed))
            {
                showTopCategories = parsed;
            }
        }

        if (Model.ShowTopTags != null)
        {
            bool parsed;
            if (bool.TryParse(Convert.ToString(Model.ShowTopTags), out parsed))
            {
                showTopTags = parsed;
            }
        }

        if (Model.ShowTopOrganizers != null)
        {
            bool parsed;
            if (bool.TryParse(Convert.ToString(Model.ShowTopOrganizers), out parsed))
            {
                showTopOrganizers = parsed;
            }
        }
    }

    var httpRequest = HttpContext.Current != null ? HttpContext.Current.Request : null;

    int pageNumber = 1;
    string pageRaw = httpRequest != null ? httpRequest.QueryString["page"] : null;
    if (!string.IsNullOrWhiteSpace(pageRaw))
    {
        int parsedPage;
        if (int.TryParse(pageRaw, out parsedPage) && parsedPage > 0)
        {
            pageNumber = parsedPage;
        }
    }

    bool isUpcoming = true;
    string upcomingRaw = httpRequest != null ? httpRequest.QueryString["upcoming"] : null;
    if (!string.IsNullOrWhiteSpace(upcomingRaw))
    {
        bool parsedUpcoming;
        if (bool.TryParse(upcomingRaw, out parsedUpcoming))
        {
            isUpcoming = parsedUpcoming;
        }
    }

    string categorySlug = httpRequest != null ? httpRequest.QueryString["category"] : null;
    string tagSlug = httpRequest != null ? httpRequest.QueryString["tag"] : null;
    string organizerSlug = httpRequest != null ? httpRequest.QueryString["organizer"] : null;
    string keyword = httpRequest != null ? httpRequest.QueryString["q"] : null;
    string sortBy = httpRequest != null ? httpRequest.QueryString["sort"] : null;

    EventListRequest listRequest = new EventListRequest
    {
        PortalId = portalId,
        PageNumber = pageNumber,
        PageSize = defaultPageSize,
        CategorySlug = categorySlug,
        TagSlug = tagSlug,
        OrganizerSlug = organizerSlug,
        Keyword = keyword,
        IsUpcoming = isUpcoming,
        SortBy = sortBy
    };

    EventListViewModel vm = EventFacade.GetListViewModel(listRequest, detailBasePath);

    EventListRequest request = vm != null ? vm.Request : null;
    PagedResult<EventListItemDto> results = vm != null ? vm.Results : null;
    IList<EventListItemDto> items = results != null && results.Items != null
        ? results.Items
        : new List<EventListItemDto>();
}

<div class="container my-4">

    <!-- CATEGORY FILTER -->
    @if (showTopCategories && vm != null && vm.ActiveCategories != null && vm.ActiveCategories.Count > 0)
    {
        <div class="mb-4 d-flex flex-wrap gap-2">

            <a href="@BuildUrl(request, null)" class="category-chip @(string.IsNullOrEmpty(vm.ActiveCategorySlug) ? "active" : "")">
                All
            </a>

            @foreach (var cat in vm.ActiveCategories)
            {
                bool isActive = vm.ActiveCategorySlug == cat.CategorySlug;

                <a href="@BuildUrl(request, cat.CategorySlug)" class="category-chip @(isActive ? "active" : "")">
                    @cat.CategoryName
                    <span class="count-badge">@cat.EventCount</span>
                </a>
            }
        </div>
    }

    <div class="row">

        <!-- MAIN -->
        <div class="col-lg-8">

            @if (items == null || items.Count == 0)
            {
                <div class="alert alert-light border text-center py-5">
                    <h4>@(vm != null ? vm.EmptyStateTitle : "No Events Found")</h4>
                    <p>@(vm != null ? vm.EmptyStateText : "There are no events matching the current filters.")</p>
                </div>
            }
            else
            {
                foreach (var item in items)
                {
                    string detailUrl = EventUrlHelper.GetDetailUrl(item, vm != null ? vm.DetailBasePath : "/events");
                    string displayTime = EventFormattingHelper.GetDisplayTime(item);

                    string imageUrl = !string.IsNullOrEmpty(item.ListImageUrl)
                        ? item.ListImageUrl
                        : item.ThumbnailImageUrl;

                    string locationText = !string.IsNullOrEmpty(item.PublicLocationText)
                        ? item.PublicLocationText
                        : (!string.IsNullOrEmpty(item.VenueName)
                            ? item.VenueName
                            : (item.City + (!string.IsNullOrEmpty(item.Region) ? ", " + item.Region : "")));

                    <div class="event-card card mb-4">

                        <div class="row g-0">

                            @if (!string.IsNullOrEmpty(imageUrl))
                            {
                                <div class="col-md-4">
                                    <a href="@detailUrl">
                                        <img src="@imageUrl" class="img-fluid w-100 object-fit-cover" alt="@item.Title" />
                                    </a>
                                </div>
                            }

                            <div class="col-md-8">
                                <div class="card-body">

                                    <div class="mb-2">

                                        @if (!string.IsNullOrEmpty(item.CategoryName))
                                        {
                                            <span class="category-chip">@item.CategoryName</span>
                                        }

                                        @if (!string.IsNullOrEmpty(displayTime))
                                        {
                                            <span class="text-muted small ms-2">@displayTime</span>
                                        }

                                    </div>

                                    <h5>
                                        <a href="@detailUrl">@item.Title</a>
                                    </h5>

                                    @if (!string.IsNullOrEmpty(item.ShortSummary))
                                    {
                                        <p>@item.ShortSummary</p>
                                    }

                                    @if (item.Tags != null && item.Tags.Count > 0)
                                    {
                                        <div class="mb-2">
                                            @foreach (var tag in item.Tags)
                                            {
                                                <span class="tag-chip">#@tag.TagName</span>
                                            }
                                        </div>
                                    }

                                    <div class="d-flex justify-content-between align-items-center">

                                        @if (!string.IsNullOrEmpty(locationText))
                                        {
                                            <span class="small text-muted">@locationText</span>
                                        }

                                        <a href="@detailUrl" class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>

                                    </div>

                                </div>
                            </div>

                        </div>

                    </div>
                }

                <!-- PAGINATION -->
                if (results != null && results.TotalPages > 1)
                {
                    <ul class="pagination">

                        @for (int i = 1; i <= results.TotalPages; i++)
                        {
                            <li class="page-item @(i == results.PageNumber ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(request, i)">
                                    @i
                                </a>
                            </li>
                        }

                    </ul>
                }
            }

        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">

            @if (showTopTags && vm != null && vm.TrendingTags != null && vm.TrendingTags.Count > 0)
            {
                <div class="sidebar-card mb-4">
                    <h6>Topics</h6>

                    @foreach (var tag in vm.TrendingTags)
                    {
                        <a href="?tag=@tag.Slug" class="topic-chip">
                            #@tag.TagName
                        </a>
                    }
                </div>
            }

            @if (showTopOrganizers && vm != null && vm.TopOrganizers != null && vm.TopOrganizers.Count > 0)
            {
                <div class="sidebar-card">
                    <h6>Organizers</h6>

                    @foreach (var org in vm.TopOrganizers)
                    {
                        <div class="d-flex align-items-center mb-3">

                            <div class="organizer-avatar">
                                @GetInitials(org.OrganizerName)
                            </div>

                            <div class="ms-2">
                                <div>@org.OrganizerName</div>
                                <small class="text-muted">@org.HostedEventCount events</small>
                            </div>

                        </div>
                    }
                </div>
            }

        </div>

    </div>

</div>
