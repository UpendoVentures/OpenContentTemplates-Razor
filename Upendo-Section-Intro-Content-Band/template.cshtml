@using System
@using Upendo.Libraries.RunsOnUpendoCore.Helpers
@inherits Satrabel.OpenContent.Components.OpenContentWebPage

@functions {
    public bool GetDetailModeSetting(dynamic settings, bool defaultValue)
    {
        try
        {
            if (settings == null)
            {
                return defaultValue;
            }

            var value = settings.DetailMode;
            if (value == null)
            {
                return defaultValue;
            }

            if (value is bool)
            {
                return (bool)value;
            }

            bool parsedValue;
            if (bool.TryParse(Convert.ToString(value), out parsedValue))
            {
                return parsedValue;
            }
        }
        catch
        {
            return defaultValue;
        }

        return defaultValue;
    }

    public string NormalizePathForDetailMode(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        path = HttpUtility.UrlDecode(path);

        if (path.IndexOf("?", StringComparison.Ordinal) >= 0)
        {
            path = path.Substring(0, path.IndexOf("?", StringComparison.Ordinal));
        }

        if (path.IndexOf("#", StringComparison.Ordinal) >= 0)
        {
            path = path.Substring(0, path.IndexOf("#", StringComparison.Ordinal));
        }

        Uri parsedUri;
        if (Uri.TryCreate(path, UriKind.Absolute, out parsedUri))
        {
            path = parsedUri.PathAndQuery;

            if (path.IndexOf("?", StringComparison.Ordinal) >= 0)
            {
                path = path.Substring(0, path.IndexOf("?", StringComparison.Ordinal));
            }
        }

        path = path.Replace("\\", "/").Trim();

        while (path.Contains("//"))
        {
            path = path.Replace("//", "/");
        }

        return path.Trim('/').ToLowerInvariant();
    }

    public bool CurrentRequestHasAdditionalPathSegments(int tabId)
    {
        try
        {
            var context = HttpContext.Current;
            if (context == null || context.Request == null || tabId <= 0)
            {
                return false;
            }

            var currentPath = NormalizePathForDetailMode(context.Request.RawUrl);
            var tabPath = NormalizePathForDetailMode(DotNetNuke.Common.Globals.NavigateURL(tabId));

            if (string.IsNullOrWhiteSpace(currentPath) || string.IsNullOrWhiteSpace(tabPath))
            {
                return false;
            }

            if (currentPath.Equals(tabPath, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            return currentPath.StartsWith(tabPath + "/", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }
}

@{
    TemplateHelper.HideAdminBorder(Model.Context.ModuleId, Model.Context.TabId);

    var detailMode = GetDetailModeSetting(Model.Settings, true);
    var hideForDetailMode = detailMode && CurrentRequestHasAdditionalPathSegments(Model.Context.TabId);

    if (hideForDetailMode)
    {
        return;
    }

    RegisterStyleSheet("template.css");

    var moduleTitle = Model.ModuleTitle != null ? Convert.ToString(Model.ModuleTitle) : string.Empty;
    var moduleAnchor = Model.ModuleAnchor != null ? Convert.ToString(Model.ModuleAnchor) : string.Empty;

    var sectionHeading = Model.SectionHeading != null ? Convert.ToString(Model.SectionHeading) : string.Empty;
    var introText = Model.IntroText != null ? Convert.ToString(Model.IntroText) : string.Empty;

    var hasSectionHeading = !string.IsNullOrWhiteSpace(sectionHeading);
    var hasIntroText = !string.IsNullOrWhiteSpace(introText);

    var backgroundColorClass = Model.Settings.BackgroundColorClass != null
        ? Convert.ToString(Model.Settings.BackgroundColorClass)
        : string.Empty;

    var marginTop = Model.Settings.MarginTop != null
        ? Convert.ToString(Model.Settings.MarginTop)
        : string.Empty;

    var marginBottom = Model.Settings.MarginBottom != null
        ? Convert.ToString(Model.Settings.MarginBottom)
        : string.Empty;

    var paddingTop = Model.Settings.PaddingTop != null
        ? Convert.ToString(Model.Settings.PaddingTop)
        : string.Empty;

    var paddingBottom = Model.Settings.PaddingBottom != null
        ? Convert.ToString(Model.Settings.PaddingBottom)
        : string.Empty;

    var headingId = "oc-split-heading-intro-" + Model.Context.ModuleId;
    if (!string.IsNullOrWhiteSpace(moduleAnchor))
    {
        headingId = moduleAnchor + "-heading";
    }

    var sectionClasses = "oc-split-heading-intro position-relative w-100";

    if (!string.IsNullOrWhiteSpace(backgroundColorClass))
    {
        sectionClasses += " " + backgroundColorClass;
    }

    if (!string.IsNullOrWhiteSpace(marginTop))
    {
        sectionClasses += " " + marginTop;
    }

    if (!string.IsNullOrWhiteSpace(marginBottom))
    {
        sectionClasses += " " + marginBottom;
    }

    if (!string.IsNullOrWhiteSpace(paddingTop))
    {
        sectionClasses += " " + paddingTop;
    }

    if (!string.IsNullOrWhiteSpace(paddingBottom))
    {
        sectionClasses += " " + paddingBottom;
    }
}

@if (!string.IsNullOrWhiteSpace(moduleAnchor))
{
    <div id="@moduleAnchor"></div>
}

<section class="@sectionClasses"@(hasSectionHeading ? " aria-labelledby=\"" + headingId + "\"" : " aria-label=\"Content section\"")>
    <div class="container-fluid py-5">
        <div class="oc-split-heading-intro__inner mx-auto">
            <div class="row g-4 g-lg-5 align-items-start">
                <div class="col-12 col-lg-5">
                    @if (!string.IsNullOrWhiteSpace(moduleTitle))
                    {
                        <div class="visually-hidden">@moduleTitle</div>
                    }

                    @if (hasSectionHeading)
                    {
                        <h2 id="@headingId" class="oc-split-heading-intro__heading mb-0">@Html.Raw(sectionHeading)</h2>
                    }
                </div>

                <div class="col-12 col-lg-7">
                    @if (hasIntroText)
                    {
                        <div class="oc-split-heading-intro__content">
                            @Html.Raw(introText)
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>