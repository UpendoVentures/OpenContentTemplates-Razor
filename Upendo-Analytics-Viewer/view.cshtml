                                                    <td class="text-end">@TemplateHelper.Formatting.FormatDecimal(item.Conversions)</td>
                                                    <td class="text-end">@TemplateHelper.Formatting.FormatDecimal(item.AvgTimeOnPageSeconds)</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
