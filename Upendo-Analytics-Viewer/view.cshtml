            <script>
                (function () {
                    var chartCanvas = document.getElementById('uvTrendChart');
                    var metricSelector = document.getElementById('uvTrendMetricSelector');
                    var comparisonToggle = document.getElementById('uvTrendComparisonToggle');

                    if (!chartCanvas || !metricSelector || typeof Chart === 'undefined') {
                        return;
                    }

                    var defaultMetric = '@defaultTrendMetric';
                    var currentMetric = uvTrendData[defaultMetric] ? defaultMetric : 'Users';

                    metricSelector.value = currentMetric;

                    function getYAxisLabel(metricName) {
                        switch (metricName) {
                            case 'Users':
                                return 'Users';
                            case 'Sessions':
                                return 'Sessions';
                            case 'PageViews':
                                return 'Page Views';
                            case 'Conversions':
                                return 'Conversions';
                            case 'Revenue':
                                return 'Revenue';
                            default:
                                return 'Value';
                        }
                    }

                    function getDatasetLabel(metricName) {
                        switch (metricName) {
                            case 'PageViews':
                                return 'Page Views';
                            default:
                                return metricName;
                        }
                    }

                    var trendChart = new Chart(chartCanvas, {
                        type: 'line',
                        data: {
                            labels: uvTrendLabels,
                            datasets: buildDatasets(currentMetric)
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                mode: 'index',
                                intersect: false
                            },
                            plugins: {
                                legend: {
                                    display: false
                                },
                                tooltip: {
                                    enabled: true,
                                    callbacks: {
                                        label: function (context) {
                                            var label = context.dataset.label || '';
                                            var value = context.parsed.y;

                                            if (currentMetric === 'Revenue') {
                                                return label + ': $' + Number(value).toFixed(2);
                                            }

                                            if (currentMetric === 'Conversions') {
                                                return label + ': ' + Number(value).toFixed(2);
                                            }

                                            return label + ': ' + Number(value).toLocaleString();
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    title: {
                                        display: true,
                                        text: getYAxisLabel(currentMetric)
                                    }
                                }
                            }
                        }
                    });

                    function updateTrendChart(metricName) {
                        if (!uvTrendData[metricName]) {
                            return;
                        }

                        currentMetric = metricName;
                        trendChart.data.datasets = buildDatasets(currentMetric);
                        trendChart.options.scales.y.title.text = getYAxisLabel(currentMetric);
                        trendChart.update();
                    }

                    function buildDatasets(metricName) {
                        var datasets = [
                            {
                                label: getDatasetLabel(metricName),
                                data: uvTrendData[metricName],
                                tension: 0.25,
                                fill: false
                            }
                        ];

                        if (
                            comparisonToggle &&
                            comparisonToggle.checked &&
                            uvHasPreviousTrendData &&
                            uvPreviousTrendData[metricName]
                        ) {
                            datasets.push({
                                label: 'Previous Period',
                                data: uvPreviousTrendData[metricName],
                                tension: 0.25,
                                fill: false,
                                borderDash: [6, 4]
                            });
                        }

                        return datasets;
                    }

                    metricSelector.addEventListener('change', function () {
                        updateTrendChart(this.value);
                    });

                    if (comparisonToggle) {
                        comparisonToggle.addEventListener('change', function () {
                            updateTrendChart(metricSelector.value);
                        });
                    }
                })();
            </script>

            <script>
                (function () {
                    var chartCanvas = document.getElementById('uvChannelChart');
                    var metricSelector = document.getElementById('uvChannelMetricSelector');

                    if (!chartCanvas || !metricSelector || typeof Chart === 'undefined') {
                        return;
                    }

                    var currentMetric = '@defaultChannelChartMetric';
                    if (!uvChannelData[currentMetric]) {
                        currentMetric = 'Sessions';
                    }

                    metricSelector.value = currentMetric;

                    function getSortedChannelData(metricName) {
                        var combined = uvChannelLabels.map(function (label, i) {
                            return {
                                label: label,
                                value: uvChannelData[metricName][i]
                            };
                        });

                        combined.sort(function (a, b) {
                            return b.value - a.value;
                        });

                        return {
                            labels: combined.map(function (x) { return x.label; }),
                            data: combined.map(function (x) { return x.value; })
                        };
                    }

                    function getDatasetLabel(metricName) {
                        switch (metricName) {
                            case 'Users':
                                return 'Users';
                            case 'EngagedSessions':
                                return 'Engaged Sessions';
                            case 'Conversions':
                                return 'Conversions';
                            case 'Sessions':
                            default:
                                return 'Sessions';
                        }
                    }

                    var sorted = getSortedChannelData(currentMetric);
                    var channelChart = new Chart(chartCanvas, {
                        type: 'bar',
                        data: {
                            labels: sorted.labels,
                            datasets: [
                                {
                                    label: getDatasetLabel(currentMetric),
                                    data: sorted.data,
                                    borderWidth: 1,
                                    backgroundColor: sorted.data.map(function (value, index) {
                                        return index === 0
                                            ? 'rgba(54, 162, 235, 0.9)'
                                            : 'rgba(54, 162, 235, 0.4)';
                                    }),
                                    borderColor: sorted.data.map(function (value, index) {
                                        return index === 0
                                            ? 'rgba(40, 167, 69, 1)'
                                            : 'rgba(54, 162, 235, 1)';
                                    })
                                }
                            ]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                mode: 'nearest',
                                intersect: true
                            },
                            plugins: {
                                legend: {
                                    display: false
                                },
                                tooltip: {
                                    enabled: true,
                                    callbacks: {
                                        title: function (context) {
                                            if (!context || !context.length) {
                                                return '';
                                            }

                                            var index = context[0].dataIndex;
                                            return uvChannelLabels[index] || '';
                                        },
                                        label: function (context) {
                                            var value = context.parsed.x;

                                            if (currentMetric === 'Sessions') {
                                                return value.toLocaleString() + ' sessions (total visits from this source)';
                                            }

                                            if (currentMetric === 'Users') {
                                                return value.toLocaleString() + ' users (people from this source)';
                                            }

                                            if (currentMetric === 'EngagedSessions') {
                                                return value.toLocaleString() + ' engaged sessions (visits where people interacted)';
                                            }

                                            if (currentMetric === 'Conversions') {
                                                return value.toLocaleString() + ' conversions';
                                            }

                                            return value.toLocaleString();
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    ticks: {
                                        precision: 0
                                    },
                                    title: {
                                        display: true,
                                        text: getDatasetLabel(currentMetric)
                                    }
                                },
                                y: {
                                    ticks: {
                                        autoSkip: false
                                    }
                                }
                            }
                        }
                    });

                    function updateChannelChart(metricName) {
                        if (!uvChannelData[metricName]) {
                            return;
                        }

                        currentMetric = metricName;

                        var sorted = getSortedChannelData(currentMetric);

                        channelChart.data.labels = sorted.labels;
                        channelChart.data.datasets[0].label = getDatasetLabel(currentMetric);
                        channelChart.data.datasets[0].data = sorted.data;
                        channelChart.data.datasets[0].backgroundColor = sorted.data.map(function (value, index) {
                            return index === 0
                                ? 'rgba(54, 162, 235, 0.9)'
                                : 'rgba(54, 162, 235, 0.4)';
                        });
                        channelChart.options.scales.x.title.text = getDatasetLabel(currentMetric);
                        channelChart.update();
                    }

                    metricSelector.addEventListener('change', function () {
                        updateChannelChart(this.value);
                    });
                })();
            </script>

