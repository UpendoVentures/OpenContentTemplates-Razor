            <script>
                var uvTrendLabels = @Html.Raw(Json.Encode(trendLabels));
                var uvTrendData = {
                    Users: @Html.Raw(Json.Encode(trendUsers)),
                    Sessions: @Html.Raw(Json.Encode(trendSessions)),
                    PageViews: @Html.Raw(Json.Encode(trendPageViews)),
                    Conversions: @Html.Raw(Json.Encode(trendConversions)),
                    Revenue: @Html.Raw(Json.Encode(trendRevenue))
                };
                var uvPreviousTrendData = {
                    Users: @Html.Raw(Json.Encode(previousTrendUsers)),
                    Sessions: @Html.Raw(Json.Encode(previousTrendSessions)),
                    PageViews: @Html.Raw(Json.Encode(previousTrendPageViews)),
                    Conversions: @Html.Raw(Json.Encode(previousTrendConversions)),
                    Revenue: @Html.Raw(Json.Encode(previousTrendRevenue))
                };
                var uvHasPreviousTrendData = @(hasPreviousTrendData ? "true" : "false");
                var uvTopPagesLabels = @Html.Raw(Json.Encode(topPagesChartLabels));
                var uvTopPagesData = {
                    Views: @Html.Raw(Json.Encode(topPagesChartViews)),
                    Entrances: @Html.Raw(Json.Encode(topPagesChartEntrances))
                };
                var uvChannelLabels = @Html.Raw(Json.Encode(channelChartLabels));
                var uvChannelData = {
                    Users: @Html.Raw(Json.Encode(channelChartUsers)),
                    Sessions: @Html.Raw(Json.Encode(channelChartSessions)),
                    EngagedSessions: @Html.Raw(Json.Encode(channelChartEngagedSessions)),
                    Conversions: @Html.Raw(Json.Encode(channelChartConversions))
                };
                var uvEventLabels = @Html.Raw(Json.Encode(eventChartLabels));
                var uvEventData = {
                    EventCount: @Html.Raw(Json.Encode(eventChartEventCount)),
                    Users: @Html.Raw(Json.Encode(eventChartUsers)),
                    Conversions: @Html.Raw(Json.Encode(eventChartConversions))
