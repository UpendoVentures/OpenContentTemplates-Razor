@using System
@using System.Linq
@using Upendo.SkinObjects.OpenContentHelper.Analytics
@using Upendo.SkinObjects.OpenContentHelper.Analytics.Models.Requests
@using Upendo.SkinObjects.OpenContentHelper.Analytics.Models.Responses
@using Upendo.SkinObjects.OpenContentHelper.Helpers

@{
    TemplateHelper.HideAdminBorder(Model.Context.ModuleId, Model.Context.TabId);

    RegisterScript("https://cdn.jsdelivr.net/npm/chart.js");

    var dashboardTitle = string.Empty;
    var siteId = 0;
    var dataSourceId = 0;
    var dateStart = DateTime.Today.AddDays(-30);
    var dateEnd = DateTime.Today;
    var showComparison = true;
    var showTrend = true;
    var showChannels = true;
    var showEvents = true;
    var showTopPages = true;
    var topN = 10;
    var showTrendEngagedSessions = true;
    var showTrendEventCount = true;
    var showTrendEngagementRate = true;
    var showTrendBounceRate = true;
    var showTrendAvgSessionDuration = true;
    
    /* charting support */    
    var defaultTrendMetric = "Users";
    var enableTrendComparisonOverlay = true;
    var defaultShowTrendComparisonOverlay = false;
    var defaultTopPagesChartMetric = "Views";
    var defaultChannelChartMetric = "EngagedSessions";

    if (Model != null)
    {
        dashboardTitle = Convert.ToString(Model.DashboardTitle ?? string.Empty);
        siteId = Model.SiteId != null ? Convert.ToInt32(Model.SiteId) : 0;
        dataSourceId = Model.DataSourceId != null ? Convert.ToInt32(Model.DataSourceId) : 0;

        if (Model.DateStart != null)
        {
            DateTime.TryParse(Convert.ToString(Model.DateStart), out dateStart);
        }

        if (Model.DateEnd != null)
        {
            DateTime.TryParse(Convert.ToString(Model.DateEnd), out dateEnd);
        }

        if (Model.ShowComparison != null)
        {
            showComparison = Convert.ToBoolean(Model.ShowComparison);
        }

        if (Model.ShowTrend != null)
        {
            showTrend = Convert.ToBoolean(Model.ShowTrend);
        }

        if (Model.ShowChannels != null)
        {
            showChannels = Convert.ToBoolean(Model.ShowChannels);
        }

        if (Model.ShowEvents != null)
        {
            showEvents = Convert.ToBoolean(Model.ShowEvents);
        }

        if (Model.ShowTopPages != null)
        {
            showTopPages = Convert.ToBoolean(Model.ShowTopPages);
        }

        if (Model.TopN != null)
        {
            topN = Convert.ToInt32(Model.TopN);
            if (topN <= 0)
            {
                topN = 10;
            }
        }

        if (Model.ShowTrendEngagedSessions != null)
        {
            showTrendEngagedSessions = Convert.ToBoolean(Model.ShowTrendEngagedSessions);
        }

        if (Model.ShowTrendEventCount != null)
        {
            showTrendEventCount = Convert.ToBoolean(Model.ShowTrendEventCount);
        }

        if (Model.ShowTrendEngagementRate != null)
        {
            showTrendEngagementRate = Convert.ToBoolean(Model.ShowTrendEngagementRate);
        }

        if (Model.ShowTrendBounceRate != null)
        {
            showTrendBounceRate = Convert.ToBoolean(Model.ShowTrendBounceRate);
        }

        if (Model.ShowTrendAvgSessionDuration != null)
        {
            showTrendAvgSessionDuration = Convert.ToBoolean(Model.ShowTrendAvgSessionDuration);
        }

        if (Model.DefaultTrendMetric != null)
        {
            defaultTrendMetric = Convert.ToString(Model.DefaultTrendMetric ?? "Users");
        }
    }

    var service = new AnalyticsService();
    var request = new AnalyticsDateRangeRequestDto
    {
        SiteId = siteId,
        DataSourceId = dataSourceId > 0 ? (int?)dataSourceId : null,
        DateStart = dateStart,
        DateEnd = dateEnd
    };
    var topNRequest = new AnalyticsTopNRequestDto
    {
        SiteId = siteId,
        DataSourceId = dataSourceId > 0 ? (int?)dataSourceId : null,
        DateStart = dateStart,
        DateEnd = dateEnd,
        TopN = topN
    };

    AnalyticsSummaryDto summary = null;
    AnalyticsComparisonSummaryDto comparison = null;
    var trend = Enumerable.Empty<AnalyticsTrendPointDto>();
    string errorMessage = null;
    var channels = Enumerable.Empty<AnalyticsChannelBreakdownDto>();
    var events = Enumerable.Empty<AnalyticsEventBreakdownDto>();
    var topPages = Enumerable.Empty<AnalyticsTopPageDto>();
    var baseUrl = string.Concat("https://", Model.Context.HTTPAlias);

    /* charting support */
    var previousTrend = Enumerable.Empty<AnalyticsTrendPointDto>();
    var hasPreviousTrendData = false;
    var previousTrendMessage = string.Empty;
    var selectedRangeDays = (dateEnd.Date - dateStart.Date).Days + 1;
    if (selectedRangeDays < 1)
    {
        selectedRangeDays = 1;
    }
    var previousDateEnd = dateStart.Date.AddDays(-1);
    var previousDateStart = previousDateEnd.AddDays(-(selectedRangeDays - 1));
    var previousRequest = new AnalyticsDateRangeRequestDto
    {
        SiteId = siteId,
        DataSourceId = dataSourceId > 0 ? (int?)dataSourceId : null,
        DateStart = previousDateStart,
        DateEnd = previousDateEnd
    };

    try
    {
        if (siteId > 0)
        {
            summary = service.GetSummary(request);
            comparison = service.GetComparisonSummary(request);
            trend = service.GetTrend(request) ?? Enumerable.Empty<AnalyticsTrendPointDto>();
            if (enableTrendComparisonOverlay)
            {
                previousTrend = service.GetTrend(previousRequest) ?? Enumerable.Empty<AnalyticsTrendPointDto>();
                hasPreviousTrendData = previousTrend.Any();

                if (!hasPreviousTrendData)
                {
                    previousTrendMessage = "No previous-period trend data is available yet for this date range.";
                }
            }
            channels = (service.GetChannelBreakdown(topNRequest) ?? Enumerable.Empty<AnalyticsChannelBreakdownDto>()).ToList();
            events = service.GetEventBreakdown(topNRequest) ?? Enumerable.Empty<AnalyticsEventBreakdownDto>();
            topPages = (service.GetTopPages(topNRequest) ?? Enumerable.Empty<AnalyticsTopPageDto>()).ToList();
        }
        else
        {
            errorMessage = "A valid Site ID is required.";
        }
    }
    catch (Exception ex)
    {
        errorMessage = ex.Message;
    }

    /* charting support */
    var trendLabels = trend != null
        ? trend.Select(x => x.MetricDate.ToString("MMM d")).ToArray()
        : new string[0];
    var trendUsers = trend != null
        ? trend.Select(x => x.Users ?? 0).ToArray()
        : new int[0];
    var trendSessions = trend != null
        ? trend.Select(x => x.Sessions ?? 0).ToArray()
        : new int[0];
    var trendPageViews = trend != null
        ? trend.Select(x => x.PageViews ?? 0).ToArray()
        : new int[0];
    var trendConversions = trend != null
        ? trend.Select(x => x.Conversions ?? 0M).ToArray()
        : new decimal[0];
    var trendRevenue = trend != null
        ? trend.Select(x => x.Revenue ?? 0M).ToArray()
        : new decimal[0];
    var previousTrendUsers = previousTrend != null
        ? previousTrend.Select(x => x.Users ?? 0).ToArray()
        : new int[0];
    var previousTrendSessions = previousTrend != null
        ? previousTrend.Select(x => x.Sessions ?? 0).ToArray()
        : new int[0];
    var previousTrendPageViews = previousTrend != null
        ? previousTrend.Select(x => x.PageViews ?? 0).ToArray()
        : new int[0];
    var previousTrendConversions = previousTrend != null
        ? previousTrend.Select(x => x.Conversions ?? 0M).ToArray()
        : new decimal[0];
    var previousTrendRevenue = previousTrend != null
        ? previousTrend.Select(x => x.Revenue ?? 0M).ToArray()
        : new decimal[0];
    var topPagesChartItems = topPages != null
        ? topPages.Take(10).ToList()
        : new List<AnalyticsTopPageDto>();
    var topPagesChartLabels = topPagesChartItems
        .Select(x =>
            !string.IsNullOrWhiteSpace(x.PageTitle)
                ? TemplateHelper.Labels.TruncateLabel(x.PageTitle, 50)
                : !string.IsNullOrWhiteSpace(x.PagePath)
                    ? TemplateHelper.Labels.TruncateLabel(x.PagePath, 50)
                    : "(Untitled Page)")
        .ToArray();
    var topPagesChartViews = topPagesChartItems
        .Select(x => x.Views ?? 0)
        .ToArray();
    var topPagesChartEntrances = topPagesChartItems
        .Select(x => x.Entrances ?? 0)
        .ToArray();
    var channelChartItems = channels != null
        ? channels.Take(10).ToList()
        : new List<AnalyticsChannelBreakdownDto>();
    var channelChartLabels = channelChartItems
        .Select(x => TemplateHelper.Labels.FormatChannelLabel(x.ChannelName))
        .ToArray();
    var channelChartUsers = channelChartItems
        .Select(x => x.Users ?? 0)
        .ToArray();
    var channelChartSessions = channelChartItems
        .Select(x => x.Sessions ?? 0)
        .ToArray();
    var channelChartEngagedSessions = channelChartItems
        .Select(x => x.EngagedSessions ?? 0)
        .ToArray();
    var channelChartConversions = channelChartItems
        .Select(x => x.Conversions ?? 0M)
        .ToArray();
        var eventChartItems = events != null
        ? events.Take(10).ToList()
        : new List<AnalyticsEventBreakdownDto>();
    var eventChartLabels = eventChartItems
        .Select(x =>
            !string.IsNullOrWhiteSpace(x.EventName)
                ? TemplateHelper.Labels.TruncateLabel(x.EventName, 50)
                : "(Unnamed Event)")
        .ToArray();
    var eventChartEventCount = eventChartItems
        .Select(x => x.EventCount ?? 0)
        .ToArray();
    var eventChartUsers = eventChartItems
        .Select(x => x.Users ?? 0)
        .ToArray();
    var eventChartConversions = eventChartItems
        .Select(x => x.Conversions ?? 0M)
        .ToArray();
    previousTrendUsers = TemplateHelper.Arrays.NormalizeIntArray(previousTrendUsers, trendLabels.Length);
    previousTrendSessions = TemplateHelper.Arrays.NormalizeIntArray(previousTrendSessions, trendLabels.Length);
    previousTrendPageViews = TemplateHelper.Arrays.NormalizeIntArray(previousTrendPageViews, trendLabels.Length);
    previousTrendConversions = TemplateHelper.Arrays.NormalizeDecimalArray(previousTrendConversions, trendLabels.Length);
    previousTrendRevenue = TemplateHelper.Arrays.NormalizeDecimalArray(previousTrendRevenue, trendLabels.Length);
    
    Func<System.Collections.IEnumerable, int> getCount = source =>
    {
        if (source == null)
        {
            return 0;
        }

        var count = 0;
        var enumerator = source.GetEnumerator();
        while (enumerator.MoveNext())
        {
            count++;
        }

        return count;
    };
}

<style>
    .metric-card {
        transition: all 0.2s ease-in-out;
        background-color: #f9fafb;
    }

    .metric-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1);
    }

    .metric-value {
        letter-spacing: -0.5px;
    }

    .metric-card a,
    table a {
        text-decoration: none;
    }

    .metric-card a:hover,
    table a:hover {
        text-decoration: underline;
    }

    #uvTrendChart {
        min-height: 320px;
    }

    .uv-dashboard-section-nav {
        position: -webkit-sticky;
        position: sticky;
        top: 1rem;
        z-index: 100;
    }

    .uv-dashboard-section-nav-inner {
        display: flex;
        flex-wrap: nowrap;
        gap: 0.75rem;
        overflow-x: auto;
        padding: 0.75rem 1rem;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.06);
        scrollbar-width: thin;
    }

    .uv-dashboard-section-link {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
        padding: 0.5rem 0.85rem;
        border-radius: 999px;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        color: #0f5c6e;
        background-color: #f8f9fa;
        border: 1px solid transparent;
        transition: all 0.2s ease;
    }

    .uv-dashboard-section-link:hover,
    .uv-dashboard-section-link:focus {
        color: #0b4452;
        background-color: #e9f7fa;
        border-color: #bfe7ef;
        text-decoration: none;
    }

    .uv-dashboard-section-link.active {
        color: #ffffff;
        background-color: #0f5c6e;
        border-color: #0f5c6e;
    }

    .uv-dashboard-section-link i {
        font-size: 0.875rem;
    }

    @@media (max-width: 767.98px) {
        .uv-dashboard-section-nav {
            top: 0.5rem;
        }

        .uv-dashboard-section-nav-inner {
            padding: 0.65rem 0.75rem;
            border-radius: 0.85rem;
        }

        .uv-dashboard-section-link {
            font-size: 0.875rem;
            padding: 0.45rem 0.75rem;
        }
    }

    .uv-back-to-top {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: #0f5c6e;
        text-decoration: none;
        padding: 0.35rem 0.6rem;
        border-radius: 999px;
        background-color: transparent;
        transition: all 0.15s ease-in-out;
    }

    .uv-back-to-top:hover,
    .uv-back-to-top:focus {
        color: #0b4452;
        background-color: #e9f7fa;
        text-decoration: none;
    }

    .uv-back-to-top i {
        font-size: 0.75rem;
    }

    .uv-back-to-top-container {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.75rem;
    }
</style>

<div id="uv-section-overview" class="uv-analytics-dashboard-test container-fluid my-4">
    <div class="row mt-4 mb-4">
        <div class="col-12">
            <h2 class="heading-primary mb-2">
                <i class="fas fa-chart-pie me-2" aria-hidden="true"></i>@dashboardTitle
            </h2>
            <p class="text-muted mb-0">
                Showing Date Range:
                <strong>@dateStart.ToString("MMM d, yyyy")</strong>
                to
                <strong>@dateEnd.ToString("MMM d, yyyy")</strong>
            </p>
            @if(Model.Context.IsEditMode){
            <p class="text-muted mb-0">
                Site ID: <strong>@siteId</strong>
                @if (dataSourceId > 0)
                {
                    <text> | Data Source ID: <strong>@dataSourceId</strong></text>
                }
            </p>
            }
        </div>
    </div>

    @if (!String.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-danger" role="alert">
                    <strong>Analytics Test Error:</strong> @errorMessage
                </div>
            </div>
        </div>
    }
    else if (summary == null)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-warning" role="alert">
                    No summary data was returned.
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row mb-3">
            <div class="col-12">
                <nav id="uvDashboardSectionNav" class="uv-dashboard-section-nav" aria-label="Dashboard section navigation">
                    <div class="uv-dashboard-section-nav-inner">
                        <a class="uv-dashboard-section-link active" href="#uv-section-overview" data-target="uv-section-overview">
                            <i class="fas fa-chart-pie me-1" aria-hidden="true"></i>Overview
                        </a>

                        @if (showComparison)
                        {
                            <a class="uv-dashboard-section-link" href="#uv-section-comparison" data-target="uv-section-comparison">
                                <i class="fas fa-exchange-alt me-1" aria-hidden="true"></i>Comparison
                            </a>
                        }

                        @if (showTrend)
                        {
                            <a class="uv-dashboard-section-link" href="#uv-section-trend" data-target="uv-section-trend">
                                <i class="fas fa-chart-line me-1" aria-hidden="true"></i>Trend
                            </a>
                        }

                        @if (showChannels)
                        {
                            <a class="uv-dashboard-section-link" href="#uv-section-channels" data-target="uv-section-channels">
                                <i class="fas fa-diagram-project me-1" aria-hidden="true"></i>Channels
                            </a>
                        }

                        @if (showEvents)
                        {
                            <a class="uv-dashboard-section-link" href="#uv-section-events" data-target="uv-section-events">
                                <i class="fas fa-bolt me-1" aria-hidden="true"></i>Events
                            </a>
                        }

                        @if (showTopPages)
                        {
                            <a class="uv-dashboard-section-link" href="#uv-section-pages" data-target="uv-section-pages">
                                <i class="fas fa-file-lines me-1" aria-hidden="true"></i>Pages
                            </a>
                        }
                    </div>
                </nav>
            </div>
        </div>
        
        <div class="row mb-4">
            <div class="col-12">
                <div class="card mb-3 shadow-sm rounded-4 border-0">
                    <div class="card-body p-3 p-md-4">
                        <div class="mb-3">
                            <h3 class="heading-secondary h4 mb-1">
                                <i class="fas fa-tachometer-alt me-2" aria-hidden="true"></i>Key Metrics
                            </h3>
                            <p class="text-muted small mb-0">A quick snapshot of overall site performance for the selected date range.</p>
                        </div>

                        <div class="row g-3">

                            <div class="row g-3 mb-4">
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="card metric-card h-100 border-0 shadow-sm rounded-4 bg-light">
                                        <div class="card-body p-3 p-md-4">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="metric-label text-muted small text-uppercase fw-normal mb-0 opacity-75" 
                                                    data-bs-toggle="tooltip" title="Percentage of sessions considered engaged during the selected date range.">Engagement Rate</div>
                                                <i class="fas fa-heartbeat text-info" aria-hidden="true"></i>
                                            </div>
                                            <div class="metric-value h2 fw-bold mb-0 text-dark letter-spacing-tight">@TemplateHelper.Formatting.FormatPercent(summary.EngagementRate)</div>
                                            @if (showComparison && comparison != null)
                                            {
                                                <div class="small mt-2 @TemplateHelper.Deltas.GetDeltaClass(comparison.EngagementRateDeltaVsPrevious)">
                                                    <i class="fas @TemplateHelper.Deltas.GetDeltaIconClass(comparison.EngagementRateDeltaVsPrevious) me-1" aria-hidden="true"></i>
                                                    @TemplateHelper.Formatting.FormatSignedDecimal(comparison.EngagementRateDeltaVsPrevious) pts vs previous
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="card metric-card h-100 border-0 shadow-sm rounded-4 bg-light">
                                        <div class="card-body p-3 p-md-4">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="metric-label text-muted small text-uppercase fw-normal mb-0 opacity-75" 
                                                    data-bs-toggle="tooltip" title="Total number of unique users during the selected date range.">Users</div>
                                                <i class="fas fa-users text-primary" aria-hidden="true"></i>
                                            </div>
                                            <div class="metric-value h2 fw-bold mb-0 text-dark letter-spacing-tight">@TemplateHelper.Formatting.FormatInt(summary.Users)</div>
                                            @if (showComparison && comparison != null)
                                            {
                                                <div class="small mt-2 @TemplateHelper.Deltas.GetDeltaClass(comparison.UsersDeltaPctVsPrevious)">
                                                    <i class="fas @TemplateHelper.Deltas.GetDeltaIconClass(comparison.UsersDeltaPctVsPrevious) me-1" aria-hidden="true"></i>
                                                    @TemplateHelper.Formatting.FormatSignedPercentNoMultiply(comparison.UsersDeltaPctVsPrevious) vs previous
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="card metric-card h-100 border-0 shadow-sm rounded-4 bg-light">
                                        <div class="card-body p-3 p-md-4">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="metric-label text-muted small text-uppercase fw-normal mb-0 opacity-75" 
                                                    data-bs-toggle="tooltip" title="Total number of visits during the selected date range.">Sessions</div>
                                                <i class="fas fa-chart-line text-success" aria-hidden="true"></i>
                                            </div>
                                            <div class="metric-value h2 fw-bold mb-0 text-dark letter-spacing-tight">@TemplateHelper.Formatting.FormatInt(summary.Sessions)</div>
                                            @if (showComparison && comparison != null)
                                            {
                                                <div class="small mt-2 @TemplateHelper.Deltas.GetDeltaClass(comparison.SessionsDeltaPctVsPrevious)">
                                                    <i class="fas @TemplateHelper.Deltas.GetDeltaIconClass(comparison.SessionsDeltaPctVsPrevious) me-1" aria-hidden="true"></i>
                                                    @TemplateHelper.Formatting.FormatSignedPercentNoMultiply(comparison.SessionsDeltaPctVsPrevious) vs previous
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="card metric-card h-100 border-0 shadow-sm rounded-4 bg-light">
                                        <div class="card-body p-3 p-md-4">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="metric-label text-muted small text-uppercase fw-normal mb-0 opacity-75" 
                                                    data-bs-toggle="tooltip" title="Total number of page views recorded during the selected date range.">Page Views</div>
                                                <i class="fas fa-eye text-info" aria-hidden="true"></i>
                                            </div>
                                            <div class="metric-value h2 fw-bold mb-0 text-dark letter-spacing-tight">@TemplateHelper.Formatting.FormatInt(summary.PageViews)</div>
                                            @if (showComparison && comparison != null)
                                            {
                                                <div class="small mt-2 @TemplateHelper.Deltas.GetDeltaClass(comparison.PageViewsDeltaPctVsPrevious)">
                                                    <i class="fas @TemplateHelper.Deltas.GetDeltaIconClass(comparison.PageViewsDeltaPctVsPrevious) me-1" aria-hidden="true"></i>
                                                    @TemplateHelper.Formatting.FormatSignedPercentNoMultiply(comparison.PageViewsDeltaPctVsPrevious) vs previous
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="card metric-card h-100 border-0 shadow-sm rounded-4 bg-light">
                                        <div class="card-body p-3 p-md-4">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="metric-label text-muted small text-uppercase fw-normal mb-0 opacity-75" 
                                                    data-bs-toggle="tooltip" title="Percentage of sessions that were not engaged during the selected date range.">Bounce Rate</div>
                                                <i class="fas fa-undo text-danger" aria-hidden="true"></i>
                                            </div>
                                            <div class="metric-value h4 fw-bold mb-0 text-dark letter-spacing-tight">@TemplateHelper.Formatting.FormatPercent(summary.BounceRate)</div>
                                            @if (showComparison && comparison != null)
                                            {
                                                <div class="small mt-2 @TemplateHelper.Deltas.GetDeltaClass(comparison.BounceRateDeltaVsPrevious)">
                                                    <i class="fas @TemplateHelper.Deltas.GetDeltaIconClass(comparison.BounceRateDeltaVsPrevious) me-1" aria-hidden="true"></i>
                                                    @TemplateHelper.Formatting.FormatSignedDecimal(comparison.BounceRateDeltaVsPrevious) pts vs previous
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="card metric-card h-100 border-0 shadow-sm rounded-4 bg-light">
                                        <div class="card-body p-3 p-md-4">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="metric-label text-muted small text-uppercase fw-normal mb-0 opacity-75" 
                                                    data-bs-toggle="tooltip" title="Total tracked revenue recorded during the selected date range.">Revenue</div>
                                                <i class="fas fa-dollar-sign text-success" aria-hidden="true"></i>
                                            </div>
                                            <div class="metric-value h4 fw-bold mb-0 text-dark letter-spacing-tight">@TemplateHelper.Formatting.FormatCurrency(summary.Revenue)</div>
                                            @if (showComparison && comparison != null)
                                            {
                                                <div class="small mt-2 @TemplateHelper.Deltas.GetDeltaClass(comparison.RevenueDeltaPctVsPrevious)">
                                                    <i class="fas @TemplateHelper.Deltas.GetDeltaIconClass(comparison.RevenueDeltaPctVsPrevious) me-1" aria-hidden="true"></i>
                                                    @TemplateHelper.Formatting.FormatSignedPercentNoMultiply(comparison.RevenueDeltaPctVsPrevious) vs previous
                                                </div>
