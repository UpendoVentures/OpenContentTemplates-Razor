            <script>
                (function () {
                    var nav = document.getElementById('uvDashboardSectionNav');
                    if (!nav) {
                        return;
                    }

                    var links = nav.querySelectorAll('.uv-dashboard-section-link');
                    if (!links || !links.length) {
                        return;
                    }

                    var sections = [];

                    for (var i = 0; i < links.length; i++) {
                        var targetId = links[i].getAttribute('data-target');
                        if (!targetId) {
                            continue;
                        }

                        var section = document.getElementById(targetId);
                        if (section) {
                            sections.push({
                                id: targetId,
                                link: links[i],
                                section: section
                            });
                        }
                    }

                    function clearActiveLinks() {
                        for (var i = 0; i < sections.length; i++) {
                            sections[i].link.classList.remove('active');
                        }
                    }

                    function setActiveLink(sectionId) {
                        clearActiveLinks();

                        for (var i = 0; i < sections.length; i++) {
                            if (sections[i].id === sectionId) {
                                sections[i].link.classList.add('active');
                                break;
                            }
                        }
                    }

                    function getStickyOffset() {
                        var navHeight = nav.offsetHeight || 0;
                        return navHeight + 24;
                    }

                    function scrollToSection(sectionId) {
                        var target = document.getElementById(sectionId);
                        if (!target) {
                            return;
                        }

                        var offset = getStickyOffset();
                        var targetTop = target.getBoundingClientRect().top + window.pageYOffset - offset;

                        window.scrollTo({
                            top: targetTop,
                            behavior: 'smooth'
                        });
                    }

                    for (var i = 0; i < sections.length; i++) {
                        (function (item) {
                            item.link.addEventListener('click', function (e) {
                                e.preventDefault();
                                setActiveLink(item.id);
                                scrollToSection(item.id);
                            });
                        })(sections[i]);
                    }

                    function updateActiveSectionOnScroll() {
                        var scrollPosition = window.pageYOffset + getStickyOffset() + 20;
                        var currentId = sections.length ? sections[0].id : null;

                        for (var i = 0; i < sections.length; i++) {
                            var sectionTop = sections[i].section.offsetTop;
                            if (scrollPosition >= sectionTop) {
                                currentId = sections[i].id;
                            }
                        }

                        if (currentId) {
                            setActiveLink(currentId);
                        }
                    }

                    window.addEventListener('scroll', updateActiveSectionOnScroll);
                    window.addEventListener('load', updateActiveSectionOnScroll);
                    window.addEventListener('resize', updateActiveSectionOnScroll);
                })();
            </script>
            <script>
                (function () {
                    function getScrollOffset() {
                        var nav = document.getElementById('uvDashboardSectionNav');
                        var navHeight = nav ? nav.offsetHeight : 0;

                        var fixedTop = window.innerWidth < 768 ? 65 : 80;

                        return navHeight + fixedTop + 16;
                    }

                    function scrollToTopSmooth() {
                        var target = document.getElementById('uv-section-overview');
                        if (!target) {
                            window.scrollTo({ top: 0, behavior: 'smooth' });
                            return;
                        }

                        var offset = getScrollOffset();
                        var targetTop = target.getBoundingClientRect().top + window.pageYOffset - offset;

                        window.scrollTo({
                            top: targetTop,
                            behavior: 'smooth'
                        });
                    }

                    document.addEventListener('click', function (e) {
                        var el = e.target.closest('.uv-back-to-top');
                        if (!el) return;

                        e.preventDefault();
                        scrollToTopSmooth();
                    });
                })();
            </script>
        }
    }
</div>